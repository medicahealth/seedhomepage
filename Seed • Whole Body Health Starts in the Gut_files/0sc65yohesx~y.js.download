  html[page-type='auth'] {
    .site-content {
      min-height: calc(100vh - 150px);
    }
  }

  html,
  body {
    display: block;
    width: 100%;
    font-family: var(--flag-font-family);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  button,
  input,
  optgroup,
  select,
  textarea {
    font-family: var(--flag-font-family);
  }

  .site-content {
    overflow: hidden;
    display: block;
    width: 100%;
    padding-top: var(--flag-site-content-padding-top);
  }

  .page-how-vs01-works {
    scroll-behavior: smooth;
    .site-content {
      overflow: visible;
    }
  }

  .site-content > .container {
    ${i.WithSiteLayoutWidth}
    ${i.WithSiteLayoutPadding}
  padding-top: 100px;
