  }

  .site-content > .container > .title {
    ${o.WithFontHeadline}
  }

  .site-content > .container > .content {
    padding-bottom: var(--spacing-48);

    > .content-wrapper {
      @media ${r.mqLargeMin} {
        display: flex;
        justify-content: space-between;
      }
    }
  }

  .page-404 {
    .site-content {
      padding-top: 0;
    }
  }

  .with-scrolled .nav-sticky {
    transform: translateY(0);
    z-index: 13;
  }
