  }

  &:before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scaleY(0.9);
    width: 100%;
    // i'm not a fan of this either but needs to be done for the short term
    height: calc(100% + 40px);
    @media ${p.mqLargeMin} {
      height: calc(100% + 50px);
    }
    transform-origin: center;
    transition: transform 0.3s;
    background-color: rgba(87, 94, 85, 0.08);
    background-color: ${({$color:e})=>"snowwhite"===e?"rgba(229, 240, 226, 0.08)":"var(--fill-brand-subtle)"};
    border-radius: var(--bdrs-m);
  }

  &.in-view {
    position: relative;

    &:before {
      transform: translate(-50%, -50%) scaleY(1);
    }

    & img {
      transform: scale(1.25);
    }

    & video {
      transform: scale(1.25);
    }

    & > span {
      top: calc(var(--space-fixed-2) * -1);
    }

    & > .block-top {
      transform: translateY(-20px);
    }

    & > .block-bottom {
      transform: translateY(20px);
    }
  }

  &:hover .video-overlay {
    opacity: 1 !important;
  }

  // design wants the buttons to behave as if hovered when the card is active
  ${({$active:e,$color:t})=>e&&`
    button {
      background: ${"seedgreen"===t?"var(--fill-primary)":"var(--fill-brand)"} !important;
      color: ${"seedgreen"===t?"var(--fill-brand)":"var(--fill-primary)"} !important;
    }
  `}
