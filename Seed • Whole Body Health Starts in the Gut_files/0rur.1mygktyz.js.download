  display: grid;

  .swiper {
    padding-inline: var(--space-outer);
    max-width: 100%;
  }

  .swiper-wrapper {
    padding-block-end: var(--space-fixed-1);
    width: 100%;
  }

  .swiper:not(.swiper-backface-hidden) .swiper-slide {
    transform: none;
    transition: none;
    opacity: 0;
  }

  .swiper-slide:not(.swiper-slide-prev, .swiper-slide-next) {
    transform: scale(0.95);
  }

  .swiper-backface-hidden .swiper-slide {
    transform: scale(0.95) translateZ(0);
    opacity: 1;
    transition: transform 0.3s ease-in-out 0.1s;
  }

  .swiper-backface-hidden .swiper-slide-prev {
    transform: translateX(-40px) translateZ(0) scale(0.95);
  }

  .swiper-backface-hidden .swiper-slide-next {
    transform: translateX(40px) translateZ(0) scale(0.95);
  }

  .swiper-slide.swiper-slide-active {
    transform: scale(1) !important;
  }

  &.in-view .swiper-backface-hidden .swiper-slide.swiper-slide-prev,
  &.in-view .swiper-backface-hidden .swiper-slide.swiper-slide-next {
    transform: scale(0.95) translateZ(0) !important;
  }

  .swiper-backface-hidden .swiper-slide.swiper-slide-active {
    transform: scale(1) translateZ(0) !important;
  }
