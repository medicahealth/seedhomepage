    margin-left: 0;
    padding: 0.5rem 1rem 0.5rem calc((100vw - 1280px) / 2);
    scroll-snap-type: none;
    -webkit-scroll-snap-type: none;
    cursor: grab;

    &.mini {
      margin: auto;
      padding: 0 5rem;
      max-width: 80rem;
      width: 100%;
      box-sizing: content-box;
    }
  }

