, Vegetarian, Ketogenic, Gluten-Free, and Intermittent Fasting. Welcome kit includes: 60 DS-01® capsules (a 30-day supply) in a refillable glass jar, plus a free travel vial to keep up your routine no matter where you go.",sku:"SYN-WK",gtin:"860340001620",...d?{aggregateRating:d}:{},brand:{"@type":"Brand",name:"Seed"},offers:{"@type":"Offer",url:"https://seed.com/daily-synbiotic",itemCondition:"http://schema.org/NewCondition",availability:"http://schema.org/InStock",acceptedPaymentMethod:[{"@type":"PaymentMethod",name:"Credit Card"},{"@type":"PaymentMethod",name:"PayPal"},{"@type":"PaymentMethod",name:"Apple Pay"}],priceSpecification:{"@type":"UnitPriceSpecification",price:"49.99",priceCurrency:"USD",priceType:"http://schema.org/MSRP"},shippingDetails:{"@type":"OfferShippingDetails",shippingRate:{"@type":"MonetaryAmount",value:"0",currency:"USD"},shippingDestination:{"@type":"DefinedRegion",addressCountry:"US"},deliveryTime:{"@type":"ShippingDeliveryTime",businessDays:{"@type":"OpeningHoursSpecification",dayOfWeek:["http://schema.org/Monday","http://schema.org/Tuesday","http://schema.org/Wednesday","http://schema.org/Thursday","http://schema.org/Friday"]},handlingTime:{"@type":"QuantitativeValue",minValue:"0",maxValue:"1",unitCode:"d"},transitTime:{"@type":"QuantitativeValue",minValue:"3",maxValue:"8",unitCode:"d"}}},hasMerchantReturnPolicy:{"@type":"MerchantReturnPolicy",merchantReturnLink:"https://help.seed.com",description:"30 Day Money-Back Guarantee on First Order without Product Return",merchantReturnDays:"30",returnFees:"0"}}},u=`${r.default.brand} • ${l.page_title}`;return(0,t.jsxs)(n.default,{children:[(0,t.jsx)("title",{children:u}),(0,t.jsx)("meta",{name:"description",content:l.page_description}),(0,t.jsx)("link",{rel:"canonical",href:"https://seed.com/daily-synbiotic"}),(0,t.jsx)("meta",{property:"og:locale",content:"en_US"}),(0,t.jsx)("meta",{property:"og:site_name",content:"Seed"}),(0,t.jsx)("meta",{property:"og:title",content:u}),(0,t.jsx)("meta",{pro