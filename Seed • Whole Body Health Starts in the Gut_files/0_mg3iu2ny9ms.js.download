  position: absolute;
  top: -4rem;
  left: 32%;
  transform: translateX(-50%);
  text-align: center;
  font-size: 12px;
  font-weight: 500;
  line-height: 110%;
  letter-spacing: 0.24px;
  text-transform: uppercase;
  opacity: 0;
  transition:
    opacity 0.5s 0.5s,
    top 0.5s 0.5s;

  .visible & {
    top: -3rem;
    opacity: 1;
  }

  &::before {
    content: '';
    position: absolute;
    top: 150%;
    left: 50%;
    height: 2rem;
    border-left: 1px dotted var(--outline-neutral);

    @media ${a.mqLargeMin} {
      height: 2.5rem;
    }
  }

  &::after {
    content: '';
    position: absolute;
    top: calc(150% + 2rem);
    left: 50%;
    transform: translate(-50%, -50%);
    border-radius: 100%;
    width: 5px;
    height: 5px;
    background: var(--fill-primary);

    @media ${a.mqLargeMin} {
      top: calc(150% + 2.5rem);
    }
  }

  &:nth-of-type(2) {
    top: -2.5rem;
    left: 69%;
    transition:
      opacity 0.5s 1s,
      top 0.5s 1s;

    .visible & {
      top: -2rem;
    }

    @media ${a.mqLargeMin} {
      top: -0.5rem;

      .visible & {
        top: 0.5rem;
      }
    }
  }
