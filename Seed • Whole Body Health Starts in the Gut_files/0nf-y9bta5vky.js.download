`;var r=i.i(148225);let e=t.css`
  .page-reference,
  .page-new-sustainability {
    .site-content {
      .white-text {
        * {
          color: #fff;
        }
      }
      * {
        color: var(--text-primary);
        font-family: var(--flag-font-family);
      }

      > .container {
        padding-top: 70px;
        padding-bottom: 70px;
        @media ${a.mqLargeMin} {
          padding-top: 160px;
        }
      }

      .sections-list {
        position: relative;
        display: block;

        > section {
          width: ${"645px"};
          max-width: 100%;
          margin: 0 auto;
          display: block;

          h1,
          h2 {
            ${r.WithFontHead}
            margin: 50px 0 0;
            @media ${a.mqLargeMin} {
              margin: 100px 0 0;
            }

            letter-spacing: var(--flag-letter-spacing-1);
            @media ${a.mqSmallMin} {
              letter-spacing: var(--flag-letter-spacing-2);
            }
          }
          h3,
          h4,
          h5,
          h6 {
            ${r.WithFontHead}
            margin: 35px 0 0;
            font-size: 26px;

            @media ${a.mqLargeMin} {
              font-size: var(--font-size-800);
            }
          }

          p {
            ${r.WithFontBody}
            margin: 35px 0 0;
            font-size: var(--font-size-400);
          }

          strong,
          b {
            ${r.WithFontBody}
            font-weight: 500;
          }
          b i {
            font-weight: 500;
          }

          ul {
            list-style-image: url(https://res.cloudinary.com/dljz0lko8/image/upload/f_auto,q_auto/w_9,h_9/favicon);
            list-style-position: outside;
            padding: 0 0 0 18px;
            margin: 35px 0 0;
          }
          ul li {
            margin: 35px 0 0;
            padding: 0 0 0 15px;
            @media ${a.mqLargeMin} {
              padding: 0 0 0 30px;
            }
            &:first-child {
              margin: 0;
            }
          }
          ul li * {
            margin: 0;
          }

          ol {
            list-style-position: outside;
            list-style-type: decimal;
            padding: 0 0 0 10px;
            margin: 35px 0 0;
          }
          ol li {
            margin: 5px 0 0;
            &:first-child {
              margin: 0;
            }
          }
          ol li * {
            margin: 0;
          }

          ol ol {
            padding: 0 0 0 20px;
            list-style-type: upper-alpha;
          }

          .bleed-screen {
            width: 100%;
            @media ${a.mqLargeMin} {
              width: calc(100% + ((100vw - 100%) / 2));
            }
          }
          .bleed-layout {
            width: 100%;
            @media ${a.mqLargeMin} {
              width: 992.5px;
            }
          }

          [data-type='small'] {
            ${r.WithFontBody}
            display: block;
          }
          [data-type='small'] > * {
            margin: 10px 0 0;
            &:first-child {
              margin: 0;
            }
          }
          [data-type='small'] * {
            font-size: var(--font-size-300);
          }

          [data-type='table'] {
            margin: 35px 0 0;
            table {
              border-color: var(--outline-neutral);
              border-collapse: collapse;
              width: 100%;
              * {
                border-color: var(--outline-neutral);
              }
            }
            td {
              vertical-align: top;
              font-size: var(--font-size-300);
              @media ${a.mqLargeMin} {
                font-size: var(--font-size-400);
              }
              * {
                font-size: var(--font-size-300);
                @media ${a.mqLargeMin} {
                  font-size: var(--font-size-400);
                }
              }
            }
            &.with-layout-fixed {
              table {
                table-layout: fixed;
                width: 100%;
              }
            }
            &.with-no-border {
              table {
                border: 0;
              }
              tr {
                border: 0;
              }
              td {
                border: 0;
                padding-top: 0;
                vertical-align: top;
                padding-bottom: 15px;
                @media ${a.mqLargeMin} {
                  padding-bottom: 0;
                }
                &:first-of-type {
                  padding-right: 10px;
                }
              }
            }
            &.with-tr-border {
              tr {
                border-width: 1px;
                border-style: solid;
              }
            }
            &.with-tr-dashed {
              tr {
                border-style: dashed;
                border-width: 1px;
                border-right: 0px;
                border-left: 0px;
              }
            }
            &.with-td-border {
              td {
                border-width: 1px;
                border-style: solid;
              }
            }
            &.with-td-dashed {
              td {
                border-width: 1px;
                border-style: dashed;
              }
            }
            &.with-td-pa2 {
              td {
                padding: var(--spacing-8);
              }
            }
            &.with-td-pv2 {
              td {
                padding-top: var(--spacing-8);
                padding-bottom: var(--spacing-8);
              }
            }
            &.with-td-pa3 {
              td {
                padding: var(--spacing-24);
              }
            }
            &.with-td-pv3 {
              td {
                padding-top: var(--spacing-24);
                padding-bottom: var(--spacing-24);
              }
            }
            &.bleed-layout {
              ${(0,r.WithSiteBleedLayout)(645)}
            }
            &.bleed-screen {
              ${r.WithSiteBleedScreen}
            }
            &.with-bullets {
              display: flex;
              flex-direction: column;
              @media ${a.mqLargeMin} {
                display: none;
              }
              table {
                ${r.HideScrollbar}
                display: block;
                overflow-x: auto;
                white-space: nowrap;
                @media ${a.mqLargeMin} {
                  display: table;
                  white-space: initial;
                }
              }
              .bullets {
                display: flex;
                justify-content: center;
                margin-top: 30px;
                .bullet {
                  margin-right: 7px;
                  width: 5px;
                  height: 5px;
                  border-radius: 50%;
                  background-color: var(--fill-neutral-light);
                  &:last-of-type {
                    margin-right: 0;
                  }
                  &.active {
                    background-color: var(--fill-brand);
                  }
                }
              }
            }
          }

          [data-type='poster'] {
            margin: 60px 0;
            @media ${a.mqLargeMin} {
              margin: 75px 0;
            }

            > .container {
              position: relative;
            }

            .label {
              display: block;
              margin: 15px 0 0;
              font-size: var(--font-size-300);
              @media ${a.mqLargeMin} {
                max-width: 495px;
              }
              i,
              span {
                font-size: var(--font-size-300);
              }
            }
            .label:empty {
              display: none;
            }

            &.with-row {
              .grid {
                width: 100%;
                .container {
                  display: flex;
                  flex-direction: row;
                  > div {
                    flex: 1;
                  }
                }
              }
            }
            &.bleed-screen {
              ${r.WithSiteBleedScreen}
            }
            &.bleed-layout {
              ${(0,r.WithSiteBleedLayout)(645)}
            }
            &.with-numeric {
              .numeric-wrap {
                position: relative;
                .numeric {
                  position: absolute;
                  top: 0;
                  font-size: 12px;
                  right: 0;
                }
              }
            }
            &.with-border-figure {
              > .container {
                border-bottom: 1px solid var(--outline-neutral);
                padding-bottom: 40px;
                margin-bottom: 15px;
              }
            }
            // GALLERY
            &:not([data-inline='true']) {
              .picture {
                background-size: cover;
                float: left;
                overflow: hidden;
                position: relative;
                border: 1px solid #fff;
                background-position: center;
                & > div {
                  height: 100%;
                }
                img {
                  display: none !important;
                }
              }

              .grid {
                display: block;
                position: relative;
                padding-bottom: 50%;
                margin: 0 -1px;
              }
              .grid > .container {
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                position: absolute;
              }

              .with-1 .picture {
                height: 100%;
                width: 100%;
              }
              .with-2 .picture {
                height: 100%;
                &:nth-child(1) {
                  width: 50%;
                }
                &:nth-child(2) {
                  width: 50%;
                }
              }
              .with-3 .picture {
                &:nth-child(1) {
                  width: 50%;
                  height: 100%;
                }
                &:nth-child(2) {
                  width: 50%;
                  height: 50%;
                }
                &:nth-child(3) {
                  width: 50%;
                  height: 50%;
                }
              }
              .with-4 .picture {
                &:nth-child(1) {
                  width: 25%;
                  height: 100%;
                }
                &:nth-child(2) {
                  width: 25%;
                  height: 100%;
                }
                &:nth-child(3) {
                  width: 50%;
                  height: 50%;
                }
                &:nth-child(4) {
                  width: 50%;
                  height: 50%;
                }
              }
            }
          }
          [data-type='poster'] + * {
            *:first-child:not(.swiper-pagination-bullet) {
              margin: 0;
            }
          }

          hr {
            border: 0;
            opacity: 0.2;
            display: block;
            border-top: 1px solid var(--outline-primary);
            position: relative;
            margin: 30px 0;
            @media ${a.mqLargeMin} {
              margin: 75px 0;
            }
            &:after {
              @media ${a.mqLargeMin} {
                content: '';
                position: absolute;
                width: calc((1440px - 100px - 100%) / 2);
                left: 100%;
                top: 0;
                border-top: 1px solid var(--outline-primary);
              }
            }
          }
          hr + * {
            margin: 0;
          }

          .info {
            background-color: var(--fill-secondary);
            padding: 30px;
            margin: 60px 0;
            @media ${a.mqLargeMin} {
              margin: 75px 0;
            }
            *:first-child {
              margin: 0;
            }
            & > *,
            a {
              font-weight: 500;
            }
            a {
              text-decoration: underline;
              cursor: pointer;
            }
          }
          .info + * {
            margin: 0;
          }

          .with-border {
            padding: var(--spacing-8);
            border: 1px solid var(--outline-neutral);
            @media ${a.mqLargeMin} {
              padding: 0;
              border: none;
            }
          }

          .with-2-columns {
            margin: 35px 0 0;
            @media ${a.mqSmallMin} {
              column-count: 2;
              column-gap: var(--spacing-24);
            }
            p {
              margin: 0;
            }
          }
          .with-3-columns {
            margin: 35px 0 0;
            @media ${a.mqSmallMin} {
              column-count: 3;
              column-gap: var(--spacing-24);
            }
            p {
              margin: 0;
            }
          }

          .text-columns {
            display: flex;
            align-items: flex-start;
            width: calc(50vw - ((50vw - 100%) / 2));
            @media ${a.mqTabletMax} {
              flex-direction: column;
              width: 100%;
            }
            & > * {
              width: 50%;
              margin-bottom: 0;
              @media ${a.mqTabletMax} {
                width: 100%;
              }
            }
            & > *:last-of-type {
              margin-left: 100px;
              @media ${a.mqTabletMax} {
                margin-left: 0;
              }
            }
          }

          .site-accordion {
            box-sizing: content-box;
            border-left: 0;
            border-right: 0;
            margin: 50px 0 0;
            @media ${a.mqLargeMin} {
              margin: 75px 0 0;
            }

            > .head {
              align-items: center;
              padding: var(--spacing-24) 0;

              .title {
                display: flex;
                flex-grow: 1;
                flex-direction: column;
                font-size: var(--font-size-400);
                padding: 0 35px 0 0;
                font-weight: 500;
                margin: 0;
                @media ${a.mqLargeMin} {
                  flex-direction: row;
                  align-items: center;
                  justify-content: space-between;
                }
                * {
                  font-size: var(--font-size-400);
                  font-weight: 500;
                  display: block;
                  margin: 0;
                }
                span {
                  font-size: var(--font-size-350);
                  font-weight: 500;
                  * {
                    margin: 0;
                    font-weight: 500;
                    display: block;
                  }
                  &:last-child {
                    font-size: var(--font-size-400);
                    font-weight: 400;
                    @media ${a.mqLargeMin} {
                      font-size: var(--font-size-350);
                    }
                  }
                  &:first-child {
                    width: 100%;
                    @media ${a.mqLargeMin} {
                      width: 80%;
                    }
                  }
                }
              }
            }
            > .body {
              .container {
                background: #fff;
                padding: 0 0 var(--spacing-24);
                > div > *:first-child {
                  margin: 0;
                }
                p {
                  margin: 0;
                }
              }
            }

            [data-type='table'] {
              margin: 0;
              .body {
                width: calc(100% + 30px);
                @media ${a.mqLargeMin} {
                  width: 100%;
                }
              }
              td {
                border: 0;
                padding: var(--spacing-24);
                padding-left: 0;
              }
              td:not(:empty) {
                border-top: 1px dashed var(--outline-neutral);
              }
              tr:first-child td {
                padding: var(--spacing-24) var(--spacing-8) var(--spacing-24) 0;
                font-weight: 500;
              }
              &.with-bullets {
                padding-bottom: 30px;
                .bullets {
                  width: calc(100% - 30px);
                  @media ${a.mqLargeMin} {
                    width: 100%;
                  }
                }
              }
            }
          }
          .site-accordion.active {
            > .head {
              .title {
                flex-grow: 1;
                position: relative;
                z-index: 1;
              }
            }
            > .body {
              > .container {
                border-top: 0;
              }
            }
          }
          .site-accordion + .site-accordion {
            margin: -1px 0 0;
            @media ${a.mqLargeMin} {
              margin: -1px 0 0;
            }
          }
          .site-accordion.with-head-th {
            .head {
              .title {
                @media ${a.mqLargeMin} {
                  transform: translateY(2px);
                }
              }
            }
            .body {
              max-height: 65px;
              visibility: hidden;
              margin-bottom: -65px;
            }
            &.active .body {
              visibility: visible;
              margin-bottom: 0;
            }
          }
          .site-accordion.with-head-th.active {
            .head {
              .title {
                @media ${a.mqLargeMin} {
                  opacity: 0;
                }
              }
            }
            .body {
              @media ${a.mqLargeMin} {
                margin-bottom: 0;
                visibility: visible;
              }
              .container {
                background-color: transparent;
                padding: 0;
              }
            }

            [data-type='table'] {
              tr:first-child td,
              tr:first-child td * {
                @media ${a.mqLargeMin} {
                  line-height: 1.5;
                  font-weight: 500;
                  border-color: transparent;
                }
              }
            }
          }

          .swiper-pagination {
            margin-top: var(--spacing-24);
          }

          .button {
            margin-top: 60px;
            @media ${a.mqLargeMin} {
              margin-top: 35px;
            }

            &.button-secondary {
              ${r.SiteButton2}
              ${r.SiteButtonHover2}
            }

            &.button-tertiary {
              display: -webkit-inline-box;
              display: -moz-inline-box;
              display: -webkit-inline-flex;
              display: -ms-inline-flexbox;
              display: inline-flex;
              background: transparent;
              text-transform: none;
              min-width: auto;
              border: none;
              height: auto;
              width: auto;
              padding: 0;

              i {
                margin: 0 var(--spacing-8) 0 0;
              }
            }
          }

