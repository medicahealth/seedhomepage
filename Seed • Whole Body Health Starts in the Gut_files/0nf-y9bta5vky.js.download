          overflow: hidden;
          position: relative;
          background-position: center;
          background-size: cover;
          height: 100%;
          width: 100%;
          & > div {
            height: 100%;
          }
          img {
            display: none !important;
          }
        }
        .grid {
          display: block;
          position: relative;
          margin: 0 -1px;
          height: 100%;
          > .container {
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            position: absolute;
          }
        }
      }
    }

    .s0 {
      display: flex;
      align-items: center;
      justify-content: left;
      margin: 0;
      @media ${a.mqSmallMin} {
        height: calc(750px - 80px);
      }
      > .container {
        height: 100%;
        display: flex;
        align-items: center;
      }

      .text {
        width: 350px;
