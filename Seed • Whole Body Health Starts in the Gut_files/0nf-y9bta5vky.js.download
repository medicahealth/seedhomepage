  .page-new-sustainability {
    .hero-section {
      .container {
        width: 100%;
        max-height: 670px !important;
        div[data-type='poster'] {
          overflow: hidden;
        }
        .text {
          margin: 0 var(--spacing-24);
          @media ${a.mqLargeMin} {
            margin: 0 auto;
            max-width: 1440px;
            padding-left: 50px;
            padding-right: 50px;
          }
          p {
            @media ${a.mqLargeMin} {
              max-width: 350px;
            }
          }
        }
      }
    }

    .site-content {
      padding-top: 0 !important;

      .fixed-width {
        width: 645px !important;
      }

      section > .container.with-flex {
        display: flex;
        flex-wrap: wrap;
      }
      section > .container > * {
        width: 100%;
      }

      .card {
        width: 100%;
        display: flex;
        flex-direction: column;
        padding: 0;
        &:not(:first-child) {
          border-top: 1px dotted var(--outline-neutral);
          margin-top: 40px;
        }
        @media ${a.mqLargeMin} {
          margin-top: 50px;
          border: 0 !important;
          width: 48% !important;
          padding-right: var(--spacing-48);
          &:first-child,
          &:nth-child(2) {
            margin-bottom: 165px !important;
          }
        }
        > * {
          order: 2;
        }
        div[data-type='poster'] {
          order: 1;
          margin: 0 -30px;
          width: 100vw;
          @media ${a.mqLargeMin} {
            height: 300px;
            max-width: 470px;
          }
        }
        h3 {
          font-size: var(--font-size-400) !important;
          font-weight: 500 !important;
          margin-bottom: 0 !important;
          z-index: 4;
          position: relative;
        }
        p {
          margin-top: 0 !important;
        }
        .small {
          margin-top: 20px;
          * {
            font-size: var(--font-size-250);
            @media ${a.mqSmallMin} {
              font-size: 13px;
            }
          }
        }
      }
    }
    .s0 {
      height: 100vh;
      position: relative;
      @media ${a.mqSmallMin} {
        height: calc(750px - 80px);
      }
      * {
        color: #fff;
      }
      div[data-type='poster'] {
        position: absolute;
