            ${p}
          }
        }
      }

      .max-width-poster {
        [data-type='poster'] {
          max-width: 500px;
        }
      }

      .sections-list {
        > section {
          margin-bottom: 100px;
          @media ${a.mqLargeMin} {
            margin-bottom: 0;
            p + p {
              margin-top: 20px;
            }
            p:first-of-type {
              margin-top: 30px;
            }
            &.hero {
              margin-bottom: 100px;
            }
          }
          &:last-of-type {
            margin-bottom: 0;
          }

          .swiper-pagination {
            margin-top: 35px;
          }

          [data-type='heading'],
          [data-type='paragraph'] {
            h2 {
              font-size: 40px;
              margin-top: 0;
              @media ${a.mqLargeMin} {
                font-size: 50px;
                margin-top: 100px;
              }
            }
            h3 {
              font-size: 26px;
              line-height: 31px;
              @media ${a.mqLargeMin} {
                font-size: 30px;
                line-height: 40px;
              }
            }
          }

          [data-type='poster'] {
            &.fig-2 {
              > .container {
                background-color: var(--fill-secondary);
                margin-bottom: var(--spacing-8);
                @media ${a.mqSmallMin} {
                  padding: 100px;
                }
              }
            }
            &.fig-5 {
              > .container {
                background-color: var(--fill-secondary);
                margin-bottom: var(--spacing-8);
                padding: var(--spacing-24);
                @media ${a.mqSmallMin} {
                  padding: 100px;
                }
              }
            }
          }

          [data-type='table'] {
            &[data-title='Prebiotic Pomegranate Extract small'] {
              width: calc(100% + 30px);
              td:not(:first-child) {
                border-left: 0;
                border-right: 0;
                min-width: 250px;
              }
              td:first-child {
                font-weight: 500;
              }
              td:last-child {
                border-right: 1px solid var(--outline-neutral);
              }
            }
            &[data-title='Quality Control Testing Battery large'] {
              tr:not(:first-child) td {
                padding-top: var(--spacing-8);
                padding-bottom: var(--spacing-8);
              }
              tr:last-child td {
                padding-bottom: var(--spacing-24);
              }
            }
            &[data-title='Quality Control Testing Battery small'] {
              padding-bottom: 0px;
              width: 100%;
              td {
                padding: var(--spacing-24) var(--spacing-8) !important;
                width: 40%;
              }
              td:first-child {
                padding-right: var(--spacing-8) !important;
                padding-left: 0 !important;
                width: 35%;
              }
              td:last-child {
                padding-right: 0 !important;
                padding-left: var(--spacing-8) !important;
                width: 25%;
              }
            }
            &[data-title='allergens--small'] {
              width: calc(100% + 30px);
              td:not(:first-child) {
                border-left: 0;
                border-right: 0;
                min-width: 180px;
              }
              td:first-child {
                font-weight: 500;
              }
              td:last-child {
                border-right: 1px solid var(--outline-neutral);
              }
            }
            &[data-title='probiotic-potency--small'],
            &[data-title='allergens--small'],
            &[data-title='chemical-contaminants-heavy-metals--small'],
            &[data-title='chemical-contaminants--small'],
            &[data-title='digestive-survivability--small'],
            &[data-title='thermostability--small'],
            &[data-title='whole-genome--sequencing--small'],
            &[data-title='water-activity--small'],
            &[data-title='Quality Control Testing Battery small'] {
              tr:last-of-type {
                border: none;
              }
            }

            &[data-title='benefit-specific-research--large'] {
              tr:not(:first-of-type) {
                td {
                  border: 1px solid #d2d7d0;
                }
              }
              td {
