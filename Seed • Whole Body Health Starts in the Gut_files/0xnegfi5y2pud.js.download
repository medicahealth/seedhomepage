aily-synbiotic/PDS-01-img3.jpg",sachet:"https://res.cloudinary.com/dljz0lko8/image/upload/f_auto,q_auto/v1649806954/PDS-08_Sachet.png",seed_circle:"https://res.cloudinary.com/dljz0lko8/image/upload/f_auto,q_auto/v1687555392/seed-circle.png",vsTablet:"https://res.cloudinary.com/dljz0lko8/image/upload/f_auto,q_auto/v1705952815/vaginal-synbiotic/vs01pill.png",vsBlister:"https://res.cloudinary.com/dljz0lko8/image/upload/f_auto,q_auto/v1716245504/cart/VS_Cart_Thumbnail_3x_1.png",vsSustain:"https://res.cloudinary.com/dljz0lko8/image/upload/f_auto,q_auto/v1706023685/vaginal-synbiotic/sustain.png"}},869436,466878,207203,46480,690622,329081,68468,t=>{"use strict";t.s(["ANALYTICS_EVENTS",()=>td,"buildMetaUserData",()=>tt,"default",()=>tc,"trackButtonClicked",()=>ti,"trackEvent",()=>tn],869436);var e=t.i(350461),r=t.i(92262);t.s(["PRODUCT_IMAGE_AM02",()=>k,"PRODUCT_IMAGE_DED",()=>x,"PRODUCT_IMAGE_DM02",()=>E,"PRODUCT_IMAGE_DS01",()=>S,"PRODUCT_IMAGE_PDS08",()=>I,"PRODUCT_IMAGE_PM02",()=>A,"PRODUCT_IMAGE_VS01",()=>P,"default",()=>C],207203),t.s(["default",()=>y],466878);var n=t.i(391398),i=t.i(191788),a=t.i(41158),o=t.i(781971),s=t.i(675466),l=t.i(30107),u=t.i(760814),c=t.i(341949),d=t.i(148225),p=t.i(126019),h=t.i(849325),f=t.i(120069),g=t.i(715367);let m=u.default.section.withConfig({displayName:"sustainability__StyledSection",componentId:"sc-ea3aa865-0"})`
  display: block;
  background-color: var(--fill-secondary);
  padding: var(--spacing-48) 0;

  @media ${c.mqLargeMin} {
    padding: 100px 0;
  }

  * {
    color: var(--text-primary);
  }

  > .container {
    ${d.WithSiteLayout};
    height: auto;
    position: relative;
    display: block;
  }

  .body img {
    width: 100%;
  }

  .foot {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;

    @media ${c.mqLargeMin} {
      margin: var(--spacing-48) 0 0;
    }
  }

  .text {
    display: flex;
    flex-direction: column;
    position: relative;
    width: 100%;
    margin: 0 0 var(--spacing-24);

    @media ${c.mqLargeMin} {
      width: 380px;
      margin: 0;
    }

    @media ${c.mqXXLargeMin} {
      width: 420px;
    }
  }

  .text h2 {
    ${d.WithFontHead};
    letter-spacing: var(--flag-letter-spacing-1);
    @media ${c.mqSmallMin} {
      letter-spacing: var(--flag-letter-spacing-2);
    }
    padding: 0 0 var(--spacing-24) 0;
    font-size: 36px;
    text-align: left;
    display: block;

    @media ${c.mqLargeMin} {
      font-size: 50px;
      padding: 0;
    }
  }

  .text .blurb {
    display: block;
    margin-top: var(--spacing-24);
    font-size: 14px;
  }

  .text .blurb span {
    font-weight: 400;
  }

  .text a {
    display: flex;
    align-items: center;
    text-decoration: none;
    cursor: pointer;
    margin: var(--spacing-24) 0 0;
    width: 100px;

    @media ${c.mqLargeMin} {
      margin: 30px 0 0;
    }

    i {
      display: flex;
      margin: 0 10px 0 0;
    }

    p {
      display: flex;

      b {
        font-size: 14px;

        &:first-of-type {
          position: relative;
          display: flex;
          align-items: center;

          &::after {
            content: '';
            display: block;
            position: relative;
            width: 9px;
            height: 9px;
            border-radius: 50%;
            margin: 0 20px;
            background-color: var(--fill-brand);
            transition: all 0.25s ease;
          }
        }
      }
    }

    &:hover,
    &:focus {
      p b::after,
      .text a:hover b::after {
        background-color: #fff;
      }
    }
  }

  .text .blurb a span {
    font-weight: 500;
    font-size: 12px;
  }

  .text .button {
    display: none;
    text-transform: inherit;
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 60px;

    @media ${c.mqLargeMin} {
      display: flex;
    }

    span {
      font-size: 14px;
    }

    i {
      transform: scale(0.6);
      padding: 0 var(--spacing-24);
    }
  }

  .text img {
    display: block;
    margin: var(--spacing-24) auto 0;

    @media ${c.mqLargeMin} {
      display: none;
    }
  }

  .media {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: flex-start;
    position: relative;
    width: 100%;

    @media ${c.mqLargeMin} {
      width: auto;
    }
  }

  .media .container {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    align-items: flex-start;
    width: 100%;
  }

  .media .poster {
    display: block;
    text-align: center;
    width: 100%;
    max-width: 100%;

    @media ${c.mqSmallMin} {
      width: 50%;
    }

    @media ${c.mqLargeMin} {
      width: 250px;
    }

    @media ${c.mqXXLargeMin} {
      width: 300px;
    }
  }

  .media .poster:last-child {
    margin: var(--spacing-24) 0 0;

    @media ${c.mqSmallMin} {
      margin: 0;
    }

    @media ${c.mqLargeMin} {
      margin: 0 0 0 var(--spacing-24);
    }

    @media ${c.mqXXLargeMin} {
      margin: 0 0 0 62px;
    }
  }

  .media .poster .thumb {
    display: flex;
    justify-content: center;
    background-blend-mode: multiply;
    background-repeat: no-repeat;
    background-position: center;
    background-color: var(--fill-secondary);
    height: 270px;
    width: 100%;

    @media ${c.mqLargeMin} {
      height: 325px;
      border-bottom: 1px solid var(--outline-primary);
    }
  }

  .media .poster:first-child .thumb {
    background-size: auto 105%;
    background-position: center;

    @media ${c.mqLargeMin} {
      background-size: auto 112%;
      background-position: -65px -35px;
    }

    @media ${c.mqXXLargeMin} {
      background-size: auto 112%;
      background-position: -50px -35px;
    }
  }

  .media .poster:last-child .thumb {
    background-size: auto 100%;
    background-position: center;

    @media ${c.mqLargeMin} {
      background-size: auto 80%;
      background-position: center 50px;
    }
  }

  .media .poster .caption {
    display: block;
    padding: var(--spacing-8) 0 0;
    font-size: 0;

    @media ${c.mqLargeMin} {
      padding: 30px 0 0;
    }
  }

  .media .poster .caption h3 {
    margin-bottom: var(--spacing-8);
    font-weight: 500;
  }

  .media .poster .caption * {
    font-size: 16px;
    text-align: center;
    display: block;

    @media ${c.mqLargeMin} {
      text-align: left;
    }
  }

  // VIDEO
  .video {
    position: relative;
    display: block;
  }

  [data-vimeo-initialized] {
    display: block;
    width: 100%;

    > div {
      @media ${c.mqLargeMin} {
        padding: 56% 0 0 !important;
      }
    }
  }

  .overlay {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 100%;
    background: transparent;
  }
`,_=(0,u.default)(p.default).withConfig({displayName:"sustainability__StyledImage",componentId:"sc-ea3aa865-1"})`
  @media (max-width: 64em) {
    max-width: 100%;
    max-height: 100%;
    width: 80% !important;
    object-fit: contain;
  }

  @media ${c.mqLargeMin} {
    padding-top: 58px;
