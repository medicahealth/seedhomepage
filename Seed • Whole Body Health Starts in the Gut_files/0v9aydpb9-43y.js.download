  .pds08-formulation {
  max-width: none !important;
  padding: 0 !important;
  background-color: var(--fill-primary);

  > .container {
    max-width: 1440px;
    padding: 30px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;

    @media ${r.mqLargeMin} {
      padding: 80px 50px 100px;
      flex-direction: row;
    }
  }

  .title {
    * {
      color: var(--text-primary);
    }

    h2 {
      font-size: 36px;
      margin-bottom: 30px;

      @media ${r.mqLargeMin} {
        font-size: 50px;
        margin-bottom: 20px;
      }
    }

    @media ${r.mqLargeMin} {
      width: 300px;
      margin-right: 50px;
    }

    > div {
      margin-top: 30px;
    }
  }

  .contents {
    flex-grow: 1;
  }

  .accordion-container {
    margin: 30px 0;

    @media ${r.mqLargeMin} {
      margin: 0;
    }
  }

  .icon-container {
    display: flex;
    flex-wrap: wrap;
    max-width: 800px;
    gap: 24px 40px;

    @media ${r.mqLargeMin} {
      margin-top: 60px;
      gap: 24px 50px;
    }

    .formulation-icon {
      display: flex;
      align-items: center;
      width: 120px;

      @media ${r.mqSmallMin} {
        width: 140px;
        max-width: 140px;
      }

      img {
        width: 36px;
        height: 36px;
      }

      span {
        margin-left: 8px;
        font-size: 12px;
        color: var(--text-primary);
      }
    }
  }

  .site-accordion {
    .head {
      @media ${r.mqLargeMin} {
        padding: 12px 0;
      }
    }

    .title {
      display: flex;
      flex-grow: 1;
      justify-content: space-between;

      span {
        display: none;

        @media ${r.mqLargeMin} {
          display: inline;
        }
      }
    }

    .body * {
      background-color: transparent;
      color: var(--text-primary);
    }
  }
}

