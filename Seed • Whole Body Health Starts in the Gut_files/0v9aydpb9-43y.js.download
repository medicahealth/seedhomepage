  #modal-pds08-facts {
  .container {
    display: flex;
    flex-direction: column;
  }

  .head {
    border-bottom: 1px solid var(--outline-primary);
    padding-bottom: 4px;

    @media ${r.mqLargeMin} {
      border-bottom-width: 2px;
      padding-bottom: 80px;
    }
  }

  .spaced {
    padding: 12px 0;
  }
    .spaced--bottom {
      padding-bottom: 12px;
    }

    .spaced--extra {
      padding: 24px 0 12px;

      @media ${r.mqLargeMin} {
        padding: 44px 0 12px;
      }
    }

    .spaced--end {
      padding: 12px 0;
      padding-bottom: 30px;

      @media ${r.mqLargeMin} {
        padding-bottom: 50px;
      }
    }

  .smaller {
    font-size: 12px;

    @media ${r.mqLargeMin} {
      font-size: 14px;
    }
  }

  .border {
    border-bottom: 1px solid var(--outline-neutral);
  }

  .border--strong {
    border-bottom: 1.5px solid var(--outline-primary);
  }

  .border--wide {
    border-bottom-width: 3px;
  }

  .flex {
    display: flex;
    justify-content: space-between;
    padding-right: 12px;

    p:nth-child(2) {
      text-align: right;
      padding-left: 20px;
    }
  }

  h2 {
    font-weight: 500;
    font-size: 26px;
    margin: 10px 0 0;

    @media ${r.mqLargeMin} {
      font-size: 50px;
      margin: 20px 0;
    }
  }

  p,
  strong,
  td,
  th,
  i,
  span {
    font-size: 14px;

    @media ${r.mqLargeMin} {
      font-size: 16px;
    }
  }

  table {
    margin-top: 30px;
    border-spacing: 0px;
  }

  th,
  td {
    border-bottom: 1px solid var(--outline-neutral);

    &:nth-child(1) {
      text-align: left;
    }

    &:nth-child(2) {
      text-align: center;
    }

    &:nth-child(3) {
      text-align: center;
    }

    &:nth-child(4) {
      text-align: right;
      padding-right: 12px;
      width: 30%;

      @media ${r.mqLargeMin} {
        width: 250px;
      }
    }
  }

  th {
    padding-bottom: 4px;
  }

  td {
    padding: 12px 0;
  }

  i {
    font-weight: 300;
    max-width: 680px;
    display: block;
  }

  p > span {
    max-width: 680px;
    display: block;
  }
}
