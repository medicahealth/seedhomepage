://res.cloudinary.com/dljz0lko8/image/upload/f_auto,q_auto/v1649730999/PDS%20PDP/fiber/GARLIC.png' alt='Garlic' height='60px' width='60px' />Garlic","1 clove","0.19g","26.3 cloves"],["<img loading=\"lazy\" src='https://res.cloudinary.com/dljz0lko8/image/upload/f_auto,q_auto/v1649731000/PDS%20PDP/fiber/SWEETPOTATO.png' alt='Sweet Potatoes' height='60px' width='60px' />Sweet Potatoes","1 medium","3.0g","1.7 sweet potatoes"],["<img loading=\"lazy\" src='https://res.cloudinary.com/dljz0lko8/image/upload/f_auto,q_auto/v1649730999/PDS%20PDP/fiber/ALMONDS.png' alt='Almonds' height='60px' width='60px' />Almonds","1/4 cup","3.2g","0.4 cups"],["<img loading=\"lazy\" src='https://res.cloudinary.com/dljz0lko8/image/upload/f_auto,q_auto/v1649730999/PDS%20PDP/fiber/BROWNRICE.png' alt='Brown Rice' height='60px' width='60px' />Brown Rice","1 cup","3.5g","1.4 cups"],["<img loading=\"lazy\" src='https://res.cloudinary.com/dljz0lko8/image/upload/f_auto,q_auto/v1649730999/PDS%20PDP/fiber/BREAD.png' alt='Multi-grain bread' height='60px' width='60px' />Multi-grain bread","1 slice","1.5g","3.3 slices"]],Y=["a1","a2"],X=["Group","Grams of fiber/day"],K=[["Children 1-3 years","19 grams"],["Children 4-8 years","25 grams"],["Boys 9-13 years","31 grams"],["Girls 9-13 years","26 grams"]],Q=({items:e,classes:t})=>(0,i.jsx)("tr",{children:e.map((e,a)=>(0,i.jsx)("td",{className:t[a],dangerouslySetInnerHTML:(0,D.createMarkup)(e)},`item-${a}`))}),Z=o.createGlobalStyle`
  .pds08-bridge-gap {
  > .container {
    display: flex;
    flex-direction: column;
    margin: 60px 0 30px;

    @media ${r.mqLargeMin} {
      flex-direction: row;
      margin: 80px 0;
    }
  }

  .bridge-text {
    @media ${r.mqLargeMin} {
      width: 300px;
      min-width: 300px;
      margin-right: 50px;
    }

    h2 {
      margin-bottom: 30px;

      span {
        display: block;
        font-size: 36px;
        font-weight: 300;
        color: var(--text-primary);
        line-height: 1.1;
      }

      @media ${r.mqLargeMin} {
        span {
          font-size: 50px;
        }
      }
    }

    p,
    > div {
      margin-top: 1em;
      color: var(--text-primary);

      @media ${r.mqLargeMin} {
        max-width: 340px;
      }
    }
  }

  .bridge-table {
    margin-top: 30px;
    flex-grow: 1;
    overflow: hidden;
    transition: max-height 500ms ease-in-out;

    @media ${r.mqLargeMin} {
      margin: 0;
      max-height: unset !important;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    td {
      color: var(--text-primary);
      font-size: 13px;
      white-space: nowrap;

      @media ${r.mqLargeMin} {
        font-size: 16px;
      }
    }

    thead {
      td {
        padding-bottom: 16px;
        font-weight: 500;
      }
    }

    tbody {
      tr {
        border-top: 1.5px solid var(--outline-neutral);
        border-bottom: 1.5px solid var(--outline-neutral);
      }

      td {
        padding: 8px 0;

        @media ${r.mqLargeMin} {
          padding: 12px 0;
        }

        &.c1 {
          display: flex;
          align-items: center;

          img {
            margin-right: 8px;
            height: 60px;
            width: 60px;
            border-radius: 50%;
            object-fit: cover;

            @media ${r.mqLargeMin} {
              margin-right: 20px;
            }
          }
        }
      }
    }

    .c2,
    .c3 {
      text-align: center;
      display: none;

      @media ${r.mqLargeMin} {
        display: table-cell;
      }
    }

    .c4 {
      text-align: right;
    }
  }

  .bridge-annotation {
    h5,
    .h5-style {
      font-weight: 500;
      font-size: 16px;
    }

    p {
      margin: 20px 0;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    td {
      font-size: 13px;
      white-space: nowrap;
    }

    thead {
      td {
        padding-bottom: 10px;
        font-weight: 500;
      }
    }

    tbody {
      tr {
        border-top: 1px solid var(--outline-neutral);
        border-bottom: 1px solid var(--outline-neutral);
      }

      td {
        padding: 8px 0;
      }
    }

    .a2 {
      text-align: right;
    }
  }

  .view-more {
    font-size: 13px;
    color: var(--text-primary);
    margin-top: 20px;
    cursor: pointer;

    &.expanded {
      display: none;
    }

    @media ${r.mqLargeMin} {
      display: none;
    }

    svg {
      margin-left: 15px;
      stroke-width: 2px;

      path {
        color: var(--text-primary);
      }
    }
  }
}

