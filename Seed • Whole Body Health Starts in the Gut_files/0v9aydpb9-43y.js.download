  #modal-pds08-usage {
  .container {
    display: flex;
    flex-direction: column;
  }

  .section {
    display: flex;
    justify-content: space-between;
    border-top: 1px solid var(--outline-primary);
    padding: var(--spacing-24) 0;
    gap: 30px;
    flex-direction: column;
    flex-grow: 1;

    @media ${r.mqLargeMin} {
      flex-direction: row;
    }
  }

  .column {
    display: flex;
    flex-direction: column;
    justify-content: space-between;

    li {
      display: flex;
      align-items: center;
      gap: 3px;
      margin: 15px 0;

      @media ${r.mqLargeMin} {
        margin: 45px 0;
      }

      img {
        width: 35px;
        max-height: 50px;
        object-fit: contain;
        margin-right: 30px;
      }
    }

    p {
      margin-top: 1em;
    }

    h5 {
      font-size: 13px;
      line-height: 24px;
      font-weight: 400;
    }
    @media ${r.mqLargeMin} {
      width: 50%;
    }
  }

  .usage-dot {
    display: inline-flex;
    height: 12px;

    i {
      transform: scale(0.6) translateY(7px);
      margin: 0 2px;
    }
  }
}

