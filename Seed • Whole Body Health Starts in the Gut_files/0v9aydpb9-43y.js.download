  .pds08-sustainability {
  max-width: none !important;
  padding: 0 !important;
  background-color: var(--fill-secondary);

  > .container {
    max-width: 1440px;
    padding: 30px;
    margin: 0px auto;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    flex-wrap: wrap;

    @media ${r.mqLargeMin} {
      flex-direction: row;
      padding: 50px;
      margin: 50px auto 100px;
    }
  }
  .psd08-img {
    width: 100%;
    display: inline-block;
  }

  .text {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    @media ${r.mqLargeMin} {
      width: 25%;
      margin-right: 50px;
    }

    .button {
      display: none;
      i {
        transform: scale(0.8);
        padding: 0 20px;
      }

      @media ${r.mqLargeMin} {
        display: flex;
      }
    }
  }

  .text-top {
    h2 {
      span {
        display: block;
        font-size: 26px;
        font-weight: 300;
        color: var(--text-primary);
        line-height: 1.1;
      }

      @media ${r.mqLargeMin} {
        span {
          font-size: 30px;
        }
      }
    }

    p {
      color: var(--text-primary);
      margin: 30px 0;
    }
  }

  .media {
    display: flex;
    flex-direction: column;
    gap: 42px;
    margin-top: 60px;
    align-items: center;

    @media ${r.mqLargeMin} {
      margin: 0;
      gap: 50px;
      flex-direction: row;
      align-items: flex-start;
    }

    img {
      height: 300px;
      width: 300px;
      object-fit: cover;
    }
  }

  .media-item {
    width: 300px;

    h4,
    .h4-style {
      font-weight: 500;
      font-size: 16px;
      margin: 15px 0 13px;

      @media ${r.mqLargeMin} {
        margin-top: 37px;
      }
    }

    h4,
    .h4-style,
    p {
      color: var(--text-primary);
    }
  }

  span {
    color: var(--text-primary) !important;
  }
}

