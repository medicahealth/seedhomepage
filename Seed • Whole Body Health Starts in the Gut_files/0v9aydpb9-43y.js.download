  .pds08-new-standard {
  max-width: none !important;
  padding: 0 !important;
  background-color: var(--fill-primary);

  > .container {
    max-width: 1440px;
    padding: 60px 30px 30px 30px;
    margin: 0 auto;

    @media ${r.mqLargeMin} {
      padding: 80px 50px 80px 50px;
    }

    > * {
      color: var(--text-primary);
    }
  }

  h2 {
    margin-bottom: 30px;

    span {
      display: block;
      font-size: 36px;
      font-weight: 300;
      color: var(--text-primary);
      line-height: 1.1;
    }

    @media ${r.mqLargeMin} {
      margin-bottom: 40px;

      span {
        font-size: 50px;
      }
    }
  }

  .mobile-cluster {
    @media ${r.mqLargeMin} {
      display: none;
    }

    .image-group {
      display: flex;
      flex-wrap: wrap;
      margin-bottom: 35px;

      .image-container {
        position: relative;
        width: 50%;
        transition: transform 500ms ease-in-out;

        &:after {
          content: '';
          display: block;
          padding-bottom: 100%;
        }

        img {
          position: absolute;
          top: 0;
          bottom: 0;
          left: 0;
          right: 0;
          width: 100%;
          height: 100%;
          object-fit: cover;
          border-radius: 50%;
        }

        &:nth-of-type(1) {
          z-index: 4;
          transform: translate(50%, 50%);
        }

        &:nth-of-type(2) {
          z-index: 3;
          transform: translate(-50%, 50%);
        }

        &:nth-of-type(3) {
          z-index: 2;
          transform: translate(50%, -50%);
        }

        &:nth-of-type(4) {
          z-index: 1;
          transform: translate(-50%, -50%);
        }
      }
    }

    &.animate {
      .image-container {
        transform: translate(0, 0) !important;
      }
    }

    .site-accordion {
      * {
        color: var(--text-primary);
      }

      .container {
        background-color: var(--fill-primary);
      }
    }
  }

  .desktop-cluster {
    display: none;
    gap: 50px;

    @media ${r.mqLargeMin} {
      display: flex;
    }

    .cluster-item {
      position: relative;
      width: 25%;

      > * {
        color: var(--text-primary);
      }

      p {
        margin-top: 1em;
      }

      .image-container {
        position: relative;
        left: -25px;
        margin-bottom: 35px;
        width: calc(100% + 50px);
        opacity: 0;
        transition:
          transform 500ms ease-in-out,
          opacity 330ms ease-in-out;

        &:after {
          content: '';
          display: block;
          padding-bottom: 100%;
        }

        img {
          position: absolute;
          top: 0;
          bottom: 0;
          left: 0;
          right: 0;
          width: 100%;
          height: 100%;
          object-fit: cover;
          border-radius: 50%;
        }
      }

      &:nth-of-type(1) {
        .image-container {
          z-index: 4;
        }
      }

      &:nth-of-type(2) {
        .image-container {
          z-index: 3;
          transform: translate(-50%, 0);
          transition-delay: 100ms;
        }
      }

      &:nth-of-type(3) {
        .image-container {
          z-index: 2;
          transform: translate(-110%, 0);
          transition-delay: 200ms;
        }
      }

      &:nth-of-type(4) {
        .image-container {
          z-index: 1;
          transform: translate(-170%, 0);
          transition-delay: 300ms;
        }
      }
    }

    &.animate {
      .image-container {
        transform: translate(0, 0) !important;
        opacity: 1;
      }
    }
  }
}

`,eg=(0,t.memo)(()=>{let e=[{img:`${n.default.cloudinary}/f_auto,q_auto/v1649199895/PDS%20PDP/newstandard1.png`,title:"Biofermentation",desc:"How bacteria are cultured impacts their viability. We optimize our biofermentation for pH, temperature, and 28 other critical growth factors. Our mediums contain no meat or dairy."},{img:`${n.default.cloudinary}/f_auto,q_auto/v1649729399/PDS%20PDP/Survivability.png`,title:"Survivability",desc:"7 of the 9 strains are microencapsulated with a lipid coating to further protect from stomach acids, digestive enzymes and bile salts during digestion. This also means that refrigeration is not required."},{img:`${n.default.cloudinary}/f_auto,q_auto/v1649199895/PDS%20PDP/newstandard3.png`,title:"Testing",desc:"We do extensive lot-to-lot testing at each step and on the final product. With 50+ QA/QC checkpoints, we monitor purity and strength under both US and EU protocols, including cGMP + HACCP."},{img:`${n.default.cloudinary}/f_auto,q_auto/v1649729399/PDS%20PDP/Clinically-derived-dosages.png`,title:"Clinically Derived Dosages",desc:"All ingredients and their included dosages have been specifically studied in a pediatric population."}];return(0,i.jsxs)("section",{className:"pds08-new-standard",children:[(0,i.jsx)(eh,{}),(0,i.jsxs)("div",{className:"container",children:[(0,i.jsxs)("h2",{children:[(0,i.jsx)("span",{children:"A new standard"}),(0,i.jsx)("span",{children:"in probiotics."})]}),(0,i.jsxs)("div",{className:"mobile-cluster animate",children:[(0,i.jsx)("div",{className:"image-group",children:e.map((e,t)=>(0,i.jsx)("div",{className:"image-container",children:(0,i.jsx)("img",{src:e.img,alt:"",loading:"lazy"})},`image-${t}`))}),e.map((e,t)=>(0,i.jsx)(q.default,{index:t,title:e.title,children:e.desc},`accrodion-${t}`))]}),(0,i.jsx)("div",{className:"desktop-cluster animate",children:e.map((e,t)=>(0,i.jsxs)("div",{className:"cluster-item",children:[(0,i.jsx)("div",{className:"image-container",children:(0,i.jsx)(y.default,{src:e.img,al