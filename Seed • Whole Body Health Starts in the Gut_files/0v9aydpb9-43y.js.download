  .pds08-meet-scicare {
  max-width: none !important;
  padding: 0 !important;
  background-color: var(--fill-secondary);

  > .container {
    max-width: 1440px;
    padding: 50px 30px 50px 30px;
    margin: 0px auto;

    @media ${r.mqLargeMin} {
      padding: 60px 50px 80px 50px;
    }
  }

  h2 {
    font-size: 26px;
    color: var(--text-primary);
    margin-bottom: 30px;

    @media ${r.mqLargeMin} {
      font-size: 30px;
    }
  }

  p {
    color: var(--text-primary);
  }

  strong {
    color: var(--text-primary);
  }

  .grid-container {
    display: grid;
    gap: 30px;
    grid-template-columns: auto;
    grid-template-rows: auto auto auto;
    grid-template-areas: 'top' 'aside' 'bottom';

    @media ${r.mqLargeMin} {
      gap: 30px 50px;
      grid-template-columns: 400px auto;
      grid-template-rows: auto 1fr;
      grid-template-areas:
        'top aside'
        'bottom aside';
    }
  }

  .top {
    grid-area: top;
  }

  .bottom {
    grid-area: bottom;
    display: flex;
    flex-direction: column;
    justify-content: space-between;

    p {
      margin-bottom: 30px;

      @media ${r.mqLargeMin} {
        margin-top: 8px;
      }
    }

    button {
      position: relative;
      left: -15px;
      width: calc(100% + 30px);
      background-color: var(--fill-secondary);
      color: var(--text-primary);
      border: 1px solid var(--outline-primary);
      border-radius: 28px;
      padding: 12px 25px;
      transition:
        background-color 0.25s ease,
        color 0.25s ease;
      font-weight: 500;

      &:focus,
      &:active {
        background-color: var(--fill-brand);
        color: white;
      }

      @media (hover: hover) and (pointer: fine) {
        &:hover {
          background-color: var(--fill-brand);
          color: white;
          cursor: pointer;
        }
      }

      @media ${r.mqLargeMin} {
        left: 0;
        width: fit-content;
      }
    }
  }

  .aside {
    position: relative;
    left: -15px;
    width: calc(100% + 30px);
    grid-area: aside;
    border-radius: 32px;
    background: var(--fill-secondary);
    box-shadow:
      inset 20px 7px 32px rgba(255, 255, 255, 0.75),
      inset 50px 47px 90px -20px #f6f5ef,
      inset -18px -19px 51px #cdccc3;
    padding: 30px;
    display: flex;
    flex-direction: column;

    @media ${r.mqLargeMin} {
      padding: 50px;
      left: 0;
      width: 100%;
    }

    .bubble {
      padding: 8px 16px;
      width: fit-content;
      max-width: calc(min(300px, 95%));
      border-radius: 18px;
      font-weight: 300;
      margin-bottom: 1px;
      font-size: 13px;
      transform: translateY(20px);
      opacity: 0;
      transition:
        transform 0.25s ease,
        opacity 0.25s ease;

      @media ${r.mqLargeMin} {
        font-size: 16px;
        padding: 16px 32px;
        max-width: 500px;
      }

      &.response {
        background-color: var(--fill-brand);
        color: white;

        &.pointed {
          border-bottom-left-radius: 0px;
        }
      }

      &.query {
        background-color: white;
        color: var(--text-primary);
        align-self: flex-end;

        &.pointed {
          border-bottom-right-radius: 0px;
        }
      }

      &.pointed {
        margin-bottom: 10px;
      }
    }

    &.visible {
      .bubble {
        transform: translateY(0px);
        opacity: 1;

        &:nth-of-type(2) {
          transition-delay: 1500ms;
        }

        &:nth-of-type(3) {
          transition-delay: 2900ms;
        }

        &:nth-of-type(4) {
          transition-delay: 3300ms;
        }
      }
    }
  }
}
