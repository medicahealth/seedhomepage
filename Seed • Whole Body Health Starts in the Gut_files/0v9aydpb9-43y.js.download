  .pds08-benefits {
  max-width: none !important;
  padding: 0 !important;

  @media ${r.mqLargeMin} {
    margin-top: 50px;
  }

  .benefits-panel > .container {
    max-width: 1440px;
    padding: 30px;
    margin: 0 auto;

    @media ${r.mqLargeMin} {
      padding: 50px 50px 70px 50px;
    }

    > * {
      color: var(--text-primary);
    }
  }

  .benefits-title {
    font-size: 36px;
    font-weight: 300;
    color: var(--text-primary);
    line-height: 1.1;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0px 30px;
    margin-bottom: 10px;

    @media ${r.mqLargeMin} {
      font-size: 50px;
      padding: 0px 50px;
      margin-bottom: 50px;
    }
  }

  .benefits-panel {
    width: 100%;

    > .container {
      position: relative;
      display: grid;
      grid-template-rows: auto auto auto;
      grid-template-columns: auto;
      grid-template-areas: 'top' 'aside' 'bottom';
      gap: 20px;

      @media ${r.mqLargeMin} {
        grid-template-rows: 1fr auto;
        grid-template-columns: 300px auto;
        grid-template-areas: 'top aside' 'bottom aside';
        gap: 0px 50px;
      }

      .top {
        grid-area: top;
      }

      .top-content {
        @media ${r.mqLargeMin} {
          position: sticky;
          top: 80px;
          height: fit-content;
        }
      }

      .bottom {
        grid-area: bottom;

        @media ${r.mqLargeMin} {
          margin-top: 50px;
        }
      }

      .aside {
        grid-area: aside;
      }
    }

    &:nth-of-type(1) {
      background-position: center;
      background-repeat: no-repeat;
      background-size: cover;
      padding-top: 30px;

      * {
        color: white !important;
        stroke: white;
      }

      .body * {
        background-color: transparent;
      }

      @media ${r.mqLargeMin} {
        padding-top: 50px;
      }
    }

    h3 {
      color: var(--text-primary);
      font-size: 26px;

      @media ${r.mqLargeMin} {
        font-size: 30px;
      }
    }

    p {
      color: var(--text-primary);
      font-size: 14px;
      margin: 1em 0;

      @media ${r.mqLargeMin} {
        font-size: 16px;
      }
    }

    h5 {
      color: var(--text-primary);
      font-size: 14px;
      font-weight: 500;
      margin-bottom: 1em;
    }

    h6,
    .h6-style {
      color: var(--text-primary);
      font-size: 13px;
      line-height: 1.5;
    }

    .title {
      color: var(--text-primary);

      span {
        color: var(--text-primary);
        margin-left: 13.5px;
        align-self: center;
      }

      sup {
        color: var(--text-primary);
        font-size: 12px;
      }

      p {
        color: var(--text-primary);
        font-weight: 400;
        margin-top: 1em;
      }
    }

    .body {
      li,
      p {
        color: var(--text-primary);
        font-size: 16px;

        &:not(:last-of-type) {
          margin-bottom: 1em;
        }
      }
    }

    .mobile-accordion {
      .title {
        display: flex;

        img {
          min-width: 80px;
          height: 80px;
          border-radius: 50%;
          object-fit: cover;
        }
      }

      @media ${r.mqLargeMin} {
        display: none;
      }
    }

    .composition-desktop-panel,
    .strain-desktop-panel {
      display: none;

      @media ${r.mqLargeMin} {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 50px;
      }
    }
  }

  .composition-desktop-panel {
    .panel-item {
      opacity: 0;
      transform: translateY(100px);
      transition:
        transform 500ms ease-in-out,
        opacity 330ms ease-in-out;

      &:nth-of-type(2) {
        transition-delay: 100ms;
      }

      &:nth-of-type(3) {
        transition-delay: 200ms;
      }

      &:nth-of-type(4) {
        transition-delay: 300ms;
      }

      &:nth-of-type(5) {
        transition-delay: 400ms;
      }
    }

    .panel-image {
      height: 100px;
      margin-bottom: 25px;

      img,
      video {
        height: 100%;
      }
    }

    &.animate {
      .panel-item {
        transform: translateY(0%) !important;
        opacity: 1;
      }
    }
  }

  .strain-desktop-panel {
    .panel-item {
      &:nth-of-type(1) {
        z-index: 10;
      }

      &:nth-of-type(2) {
        z-index: 5;

        .panel-image {
          img,
          video {
            transform: translateX(-75%);
            transition-delay: 100ms;
          }
        }
      }

      &:nth-of-type(3) {
        .panel-image {
          img,
          video {
            transform: translateX(-150%);
            transition-delay: 200ms;
          }
        }
      }
    }

    .panel-image {
      position: relative;
      left: -25px;
      width: calc(100% + 50px);
      margin-bottom: 25px;
      aspect-ratio: 1/1;
      img,
      video {
        height: 100%;
        width: 100%;
        border: 1px solid var(--outline-neutral);
        object-fit: cover;
        border-radius: 50%;
        opacity: 0;
        transition:
          transform 500ms ease-in-out,
          opacity 330ms ease-in-out;
      }
    }

    &.animate {
      .panel-image {
        img,
        video {
          transform: translateX(0%) !important;
          opacity: 1;
        }
      }
    }
  }

  .panel-item {
    .panel-title {
      color: var(--text-primary);
      font-weight: 500;
    }

    .panel-content {
      li {
        color: var(--text-primary);
        border-bottom: 1px solid var(--outline-neutral);
        padding: 10px 0;

        &:first-of-type {
          border-top: 1px solid var(--outline-neutral);
        }
      }
    }
  }

  .padding-80 {
    padding: 50px;
  }
}

