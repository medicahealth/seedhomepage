.pds08-hero {
  .hero-banner {
    max-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-flow: column;

    @media ${r.mqLargeMin} {
      height: calc(100vh - 100px);
      margin-right: 30px;
      justify-content: none;
      flex-flow: row;
    }

    h1 {
      width: 100%;
      white-space: nowrap;
      position: relative;
      margin-bottom: 20px;

      span {
        display: block;
        font-size: var(--font-size-600);
        font-weight: 300;
        color: var(--text-primary);
        line-height: 1.1;

        &.age-clarification {
          padding-top: var(--spacing-8);
          padding-left: 2px;
          font-size: var(--font-size-400);
          font-weight: 400;
        }
      }

      @media ${r.mqLargeMin} {
        width: fit-content;
        margin-bottom: 0px;
        position: absolute;

        span {
          font-size: var(--font-size-1000);
        }
      }
    }
  }

  .image-container {
    margin: auto;
    margin-right: 1.5%;
    position: relative;
    width: 100%;
    height: 644px;
    max-height: 80vh;

    @media ${r.mqLargeMin} {
      width: 50%;
      margin-left: 25%;
    }

    img {
      height: 100%;
      width: 100%;
      object-fit: contain;
    }
  }

  .cta-container {
    position: relative;
  }

  .site-buy {
  ${k.WithSiteLayout}
  position: relative;
  display: block;
  z-index: 2;

  @media ${r.mqLargeMin} {
    justify-content: flex-end;
    display: flex;
    min-width: 300px;
    margin-top: 0;
  }

  @media ${r.mqXXLargeMin} {
    justify-content: flex-end;
    display: flex;
    margin-top: 0;
  }
}
.srp0text .site-buy {
  @media ${r.mqLargeMin} {
    justify-content: flex-start;
  }

  @media ${r.mqXXLargeMin} {
    justify-content: flex-start;
  }
}
.site-buy .container {
  width: 100% !important;
  position: relative;

  @media ${r.mqLargeMin} {
    width: 300px;
  }
}
.srp0text .site-buy .container {
  width: 100%;
  position: relative;
}
.site-buy .blurb {
  margin: var(--spacing-24) 0 0;
  p {
    font-size: 13px;
    margin-top: var(--spacing-8)/2;
    * {
      font-size: 13px;
    }
    strong {
      padding-right: 5px;
    }
    &.bg-green {
      display: inline-block;
      background: #b9f6a3;
      padding: 3px 5px 1px;
      margin-top: 0;
    }
    & span {
      font-weight: 500;
      font-size: 13px;
    }
  }
}
.site-buy .list {
  display: block;
  position: relative;
  margin: var(--spacing-24) 0 0;
  width: 100%;

  @media ${r.mqLargeMin} {
    transition: all .25s ease;
  }
}
.site-buy .list li {
  font-size: var(--font-size-350);
  line-height: 1.75;

  a {
    all: unset;
    text-decoration: underline;
    cursor: pointer;
  }
}
.site-buy .button {
  position: relative;
  text-transform: inherit;
  padding: var(--spacing-24) 0;
  margin: var(--spacing-8) 0 0;
  width: 100%;

  &:focus {
    outline: solid 2px black;
    outline-offset: 3px;
  }
}

.page-vaginal-synbiotic {
  .site-buy .button {
    margin: var(--spacing-24) 0 0;
  }
}

.site-buy .button i {
  transform: scale(0.8);
  padding: 0 var(--spacing-24);
}
.site-buy .button * {
  font-size: var(--font-size-400);
  font-weight: 500;
  color: #fff;

  @media ${r.mqLargeMin} {
    font-weight: 500;
  }
}
.site-buy .promoCodeIndicator {
  text-align: center;
  background-color: var(--guidance-secondary);
  padding: 8px 12px;
  margin-top: 15px;
  margin-bottom: 15px;
  border-radius: 24px;
  font-size: 14px;
}

  .site-buy {
    padding: 0;

    .container {
      position: relative;

      @media (min-width: 64em) and (max-width: 90em) and (max-height: 45em) {
        bottom: 20px;
      }

      @media ${r.mqLargeMin} {
        transform: translateY(50%);
        bottom: 0;
        position: absolute;
      }
    }

    .blurb {
      .bg-green {
        font-size: var(--font-size-400);
        color: var(--text-primary);
        background: none !important;
        padding: 0 !important;
        margin-bottom: 1em;
      }

      p {
        color: var(--text-primary);
      }

      div {
        margin-bottom: 30px;

        button {
          margin: 0;
        }

        span {
          font-size: 13px;
          color: var(--text-primary);
          text-decoration: underline;
        }
      }
    }

    .list {
      li {
        color: var(--text-primary);

        a {
          all: unset;
          text-decoration: underline;
          cursor: pointer;
        }
      }
    }

    .button {
      margin-bottom: 30px;

      &:focus,
      &:active {
        background-color: #fff;
        * {
          color: var(--text-primary);
        }
      }

      @media (hover: hover) and (pointer: fine) {
        &:hover {
          background-color: #fff;
          * {
            color: var(--text-primary);
          }
        }
      }
    }
  }

  .hero-scrolly {
    width: calc(100% + 20px);
    background-color: var(--guidance-secondary);
    margin: 60px -10px 0;
    border-radius: 8px;
    padding: 30px 15px;
    display: flex;
    flex-direction: column;

    @media ${r.mqLargeMin} {
      flex-direction: row;
      padding: 50px;
      border-radius: 16px;
      margin-top: 0px;
    }

    h2 {
      font-size: 14px;
      font-weight: 500;
      letter-spacing: 0.7px;
      margin: 0 0 20px;
      color: var(--text-primary);
      text-transform: uppercase;
    }

    li {
      font-size: 20px;
      font-weight: 300;
      color: var(--text-primary);
      padding: 10px 0;

      @media ${r.mqLargeMin} {
        font-size: 30px;
      }

      &:not(:last-of-type) {
        border-bottom: 1px solid var(--outline-neutral);
      }
    }

    .left {
      @media ${r.mqLargeMin} {
        max-width: 50%;
        margin-right: 80px;
      }
    }

    .right {
      display: flex;
      flex-direction: column;
      justify-content: space-around;
    }
  }

  .scrolly-icons {
    h5 {
      font-weight: 400;
      color: var(--text-primary);
      margin: 30px 0;
    }

    margin-bottom: 30px;
  }

  .scrolly-icons-grid {
    display: grid;
    grid-template-rows: repeat(3, 1fr);
    grid-template-columns: repeat(2, 1fr);
    grid-gap: 24px;

    @media ${r.mqLargeMin} {
      grid-template-rows: repeat(2, 1fr);
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .scrolly-icons-grid-item {
    display: flex;
    align-items: center;

    h6,
    .h6-style {
      font-size: 14px;
      margin-left: 8px;
      color: var(--text-primary);
      font-weight: 400;
    }

    svg {
      fill: none;
      stroke: var(--outline-primary);
    }
  }

  span:not(.site-buy *) {
    color: var(--text-primary) !important;
  }
}

