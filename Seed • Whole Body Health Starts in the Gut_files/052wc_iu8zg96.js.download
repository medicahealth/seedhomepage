  .page-vaginal-synbiotic {
    .site-content {
      margin-top: var(--flag-vaginal-margin);
      padding-top: var(--flag-vaginal-padding-mobile);

      @media ${c.mqLargeMin} {
        padding-top: var(--flag-vaginal-padding);
      }
      #srp0-sticky {
        z-index: 100;
        transform: translateY(0);
      }
      #srp0-container {
        max-width: 1440px;
        align-items: center;
        display: block;
        margin: 0px 30px;
      }
      #add-to-cart-new {
        display: none;
      }
      .s-hero {
        display: flex;
        justify-content: center;
        margin: 0 0 var(--spacing-48) 0;
        @media screen and (min-width: 64em) and (max-width: 90em) and (max-height: 45em) {
          height: 100vh;
          overflow: hidden;
        }

        > .container {
          position: relative;
          display: block;
          @media screen and (min-width: 64em) and (max-width: 90em) and (max-height: 45em) {
            height: 100%;
            .swiper {
              height: 100%;
              .hero,
              .hero .media .img {
                height: 100%;
                > div {
                  height: 100%;
                  img {
                    min-width: auto !important;
                    width: auto !important;
                  }
                }
              }
            }
          }
        }

        * {
          color: var(--text-primary);
        }

        .title {
          ${I.WithSiteLayout}
          padding-top: var(--spacing-24);
          padding-bottom: var(--spacing-24);
          display: block;
          @media ${c.mqLargeMin} {
            width: calc(100% - 60px);
            transform: translate(-50%, -50%);
            padding: 0;
            position: absolute;
            z-index: 2;
            pointer-events: none;
            left: 50%;
            top: 45%;
          }
        }
        .title .container {
          display: block;
          @media ${c.mqLargeMin} {
            padding: 0 50px;
          }
        }
        .title .container h1 {
          ${I.WithFontHead}
          letter-spacing: var(--flag-letter-spacing-1);
          @media ${c.mqSmallMin} {
            letter-spacing: var(--flag-letter-spacing-2);
          }
          display: inline-block;
          font-size: var(--font-size-600);
          @media ${c.mqLargeMin} {
            display: block;
            font-size: var(--font-size-1000);
          }
        }

        .srp0title {
          ${I.WithSiteLayout}
          padding-top: var(--spacing-24);
          padding-bottom: var(--spacing-24);
          display: block;
          @media ${c.mqLargeMin} {
            padding: 0;
            z-index: 2;
            pointer-events: none;
            left: 50%;
            top: 45%;
            margin-bottom: 12px;
          }
          h1.hero-title {
            display: flex;
            flex-direction: column;
            align-content: flex-start;
            gap: 8px;

            @media ${c.mqLargeMin} {
              gap: 24px;
            }

            span.title-text {
              font-weight: 350;
              font-size: 26px;
              line-height: 32px;

              @media ${c.mqLargeMin} {
                font-size: 40px;
                line-height: 44px;
              }
            }
          }
        }
        .srpCouponAmount {
          background-color: #e9f0ca;
          border-radius: 24px;
          width: 70px;
          height: 18px;
          font-size: 12px;
          padding: 4px 8px 4px;
          display: inline-block;
          vertical-align: middle;
          text-align: center;
          align-items: center;
          font-weight: 500;
          margin-left: 8px;
          margin-top: -2px;
          line-height: 12px;
        }
        .srp0title .container {
          display: block;
          @media ${c.mqSmallMax} {
            margin-left: -30px;
          }
        }

        .site-buy {
          ${I.WithSiteLayout}
          position: relative;
          display: block;
          z-index: 2;

          @media ${c.mqLargeMin} {
            justify-content: flex-end;
            display: flex;
            min-width: 300px;
            margin-top: 0;
          }

          @media ${c.mqXXLargeMin} {
            justify-content: flex-end;
            display: flex;
            margin-top: 0;
          }
        }
        .srp0text .site-buy {
          @media ${c.mqLargeMin} {
            justify-content: flex-start;
          }

          @media ${c.mqXXLargeMin} {
            justify-content: flex-start;
          }
        }
        .site-buy .container {
          width: 100% !important;
          position: relative;

          @media ${c.mqLargeMin} {
            width: 302px;
          }
        }
        .srp0text .site-buy .container {
          width: 100%;
          position: relative;
        }
        .site-buy .blurb {
          margin: var(--spacing-24) 0 0;
          p {
            font-size: 13px;
            margin-top: var(--spacing-8) / 2;
            * {
              font-size: 13px;
            }
            strong {
              padding-right: 5px;
            }
            &.bg-green {
              display: inline-block;
              background: #b9f6a3;
              padding: 3px 5px 1px;
              margin-top: 0;
            }
            & span {
              font-weight: 500;
              font-size: 13px;
            }
          }
        }
        .site-buy .list {
          display: block;
          position: relative;
          margin: var(--spacing-24) 0 0;
          width: 100%;

          @media ${c.mqLargeMin} {
            transition: all 0.25s ease;
          }
        }
        .site-buy .list li {
          font-size: var(--font-size-350);
          line-height: 1.75;

          a {
            all: unset;
            text-decoration: underline;
            cursor: pointer;
          }
        }
        .site-buy .button {
          position: relative;
          text-transform: inherit;
          padding: var(--spacing-24) 0;
          margin: var(--spacing-8) 0 0;
          width: 100%;

          &:focus {
            outline: solid 2px black;
            outline-offset: 3px;
          }
        }

        .page-vaginal-synbiotic {
          .site-buy .button {
            margin: var(--spacing-24) 0 0;
          }
        }

        .site-buy .button i {
          transform: scale(0.8);
          padding: 0 var(--spacing-24);
        }
        .site-buy .button * {
          font-size: var(--font-size-400);
          font-weight: 500;
          color: #fff;

          @media ${c.mqLargeMin} {
            font-weight: 500;
          }
        }
        .site-buy .promoCodeIndicator {
          text-align: center;
          background-color: var(--guidance-secondary);
          padding: 8px 12px;
          margin-top: 15px;
          margin-bottom: 15px;
          border-radius: 24px;
          font-size: 14px;
        }

        .site-buy {
          padding-left: 0px;
          padding-right: 0px;
          .container {
            @media screen and (min-width: 64em) and (max-width: 90em) and (max-height: 45em) {
              bottom: 20px;
            }
          }
          .button {
            &:hover,
            &:focus {
              @media ${c.mqSmallMax} {
                background-color: #fff;
              }
              * {
                @media ${c.mqSmallMax} {
                  color: var(--text-primary);
                }
              }
            }
          }
        }

        .hero > .container {
          display: flex;
          flex-direction: column;
          background-color: #fff;
          height: 100%;
          width: 100%;
          margin-bottom: 10px;
        }

        .hero .media {
          ${I.WithSiteLayoutPadding}
          margin-left: auto;
          margin-right: auto;
          position: relative;
          display: block;
          width: 100%;
          overflow: hidden;
        }
        .hero .media .img {
          position: relative;
          display: none;
          width: 100%;
          &.sm {
            display: block;
          }
          @media ${c.mqLargeMin} {
            &.lg {
              display: block;
            }
            &.sm {
              display: none;
            }
          }
        }

        .srpHero .srp0media {
          @media ${c.mqLargeMin} {
            display: flex;
            flex-direction: column;
            justify-content: center;
          }

          .img {
            position: relative;
            display: none;
            width: 100%;

            &.sm {
              display: block;
            }
            @media ${c.mqLargeMin} {
              &.lg {
                display: block;
                left: -20%;
                scale: 2.2;
              }
              &.sm {
                display: none;
              }
            }
            img {
              object-fit: cover;
            }
          }
        }

        .hero .text {
          ${I.WithSiteLayoutWidth}
          ${I.WithSiteLayoutPadding}
          padding-top: 30px;
          z-index: 1;
          @media ${c.mqLargeMin} {
            transform: translateX(-50);
            position: absolute;
            left: 50%;
            top: 29.5%;
          }
          @media screen and (min-width: 64em) and (max-width: 90em) and (max-height: 45em) {
            top: 30%;
          }
        }
        .srpHero .srp0text {
          ${I.WithSiteLayoutWidth}
          z-index: 1;
          @media ${c.mqLargeMin} {
            justify-content: center;
            flex: 1 1 0;
          }
          @media screen and (min-width: 64em) and (max-width: 90em) and (max-height: 45em) {
            top: 30%;
          }
          display: flex;
          flex-direction: column;
        }
        .srpHero .srp0text .srp0title p {
          display: none;
        }
        .hero .text > .container {
          @media ${c.mqLargeMin} {
            width: 302px;
            max-width: 100%;
            float: right;
          }
        }
        .hero .text {
          b {
            display: block;
            margin: 0 0 10px;
          }
          p {
            display: block;
            font-size: var(--font-size-400);
          }
          h2,
          h6 {
            display: block;
            font-size: 13px;
            padding-top: var(--spacing-8);
            font-weight: 400;
            line-height: 1.5;
          }
        }
        .srpHero {
          @media ${c.mqLargeMin} {
            position: relative;
            width: 100vw;
            max-width: 1440px;
            justify-content: space-around;
            display: flex;
            padding: var(--flag-hero-padding) 48px 100px 48px;
            min-height: 750px;
          }

          .srp0text {
            b {
              display: block;
              margin: 0 0 10px;
            }
            p {
              display: block;
              font-size: 16px;
              line-height: 24px;
              font-weight: 400;
            }
            h2,
            h6 {
              display: block;
              font-size: 13px;
              padding-top: var(--spacing-8);
              font-weight: 400;
              line-height: 1.5;
            }
          }
        }
        .swiper-scrollbar-container {
          transform: translateX(-50%);
          ${I.WithSiteLayoutWidth}
          position: absolute;
          z-index: 1;
          left: 50%;
          @media ${c.mqLargeMin} {
            top: 38% !important;
          }
          @media screen and (min-width: 64em) and (max-width: 90em) and (max-height: 45em) {
            top: 30% !important;
          }
        }
        .swiper-scrollbar {
          transition: 'opacity .25s ease';
          position: absolute;
          right: var(--spacing-32);
          background-color: rgba(28, 58, 19, 0.1);
          height: 4px;
          width: calc(100% - 60px);
          border-radius: 0;
          @media ${c.mqLargeMin} {
            width: 302px;
            right: 50px;
          }
        }
        .swiper-scrollbar-drag {
          background-color: var(--fill-brand);
          border-radius: 0;
          height: 4px;
        }

        .swiper {
          &.start {
            .cursor-nav-prev {
              cursor: default;
              opacity: 0.4;
              background: transparent;
              border: 0;
            }
          }
          &.end {
            .cursor-nav-next {
              cursor: default;
              opacity: 0.4;
              background: transparent;
              border: 0;
            }
          }
        }
        .cursor-nav {
          flex-wrap: wrap;
          position: absolute;
          top: 0;
          left: 0;
          height: 100%;
          width: 100%;
          z-index: 2;
          top: -40px;
          border: 1px;
          display: flex;
          align-items: center;
          height: 20px;
        }
        .cursor-nav-prev,
        .cursor-nav-next {
          background: transparent;
          position: relative;
          height: 100%;
          display: flex;
          align-items: center;
          cursor: pointer;
          transition: 'all 0.3s ease';
          border: 0;
        }
        .cursor-nav-prev {
          margin-right: 12px;
          transform: rotate(-180deg);
          position: relative;
          top: 1px;
        }

        .swiper-prev-next {
          ${I.WithSiteLayout}
          transition: 'opacity .5s ease';
          justify-content: space-between;
          display: flex;
          position: relative;
          z-index: 2;
          height: 0;
          @media ${c.mqLargeMin} {
            display: none !important;
          }
        }
        .swiper-button-prev,
        .swiper-button-next {
          margin-top: 38%;
