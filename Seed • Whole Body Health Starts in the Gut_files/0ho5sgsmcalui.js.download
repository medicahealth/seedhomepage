#modal-share {
  .site-popup-card {
    max-width: 375px;
    padding: 0 var(--spacing-32);
  }
  .head {
    padding-bottom: 0;
    @include clearfix();
  }
  .head > * {
    float: left;
    line-height: 21px;
  }
  .head > p:first-child {
    ${m.Ellipsis}
    max-width: 150px;
  }
  .body {
    margin-top: 168px;
  }
  .blurb {
    ${m.WithFontBody}
  }
  ul {
    margin-top: 38px;
    border-bottom: 1px solid var(--outline-neutral);
  }
  li {
    display: block;
    border-top: 1px solid var(--outline-neutral);
  }
  a {
    line-height: 50px;
    cursor: pointer;
  }
  a .icon {
    display: inline-block;
    margin-right: var(--spacing-24);
    font-size: 18px;
    width: 18px;
  }
  a .text {
    ${m.WithFontBody}
    display: inline-block;
  }
}
