`,y=n.default.div.withConfig({displayName:"site-filter__ListItem",componentId:"sc-d715c1d1-8"})`
  line-height: 16px;
  margin-bottom: 0;
  padding: 5px 0;

  .tag {
    text-align: left;
    width: 100%;
    border: none;
    font-size: 14px;
  }

  &.active {
    font-weight: 500;
  }

  transition: opacity 0.5s ease;
  margin-bottom: var(--spacing-24);
  cursor: pointer;
  opacity: 0.8;

  @media ${r.mqLargeMin} {
    margin-bottom: var(--spacing-8);
  }

  &:hover {
    opacity: 1;
  }
  &:last-child {
    margin-bottom: 0;
  }
  &.active {
    display: none;
    opacity: 1;
    @media ${r.mqLargeMin} {
      display: block;
    }
  }
  &.active:before {
    display: none;
    font-size: 13px;
    margin-right: var(--spacing-8);
    @media ${r.mqLargeMin} {
      display: inline-block;
    }
  }

  &.sub-item {
    margin-left: 35px;
  }
