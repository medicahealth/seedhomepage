  width: 100%;

  * {
    font-size: 16px;
  }

  &.active {
    .head {
      .title {
        font-weight: 500;
      }
      .icon svg {
        transform: translateY(-2px) rotate(180deg);
      }
    }
  }

  &.site-filter-lg {
    padding: 0 var(--spacing-48) 0 0;
    position: relative;
    width: 100%;
    border: 0;
    margin: 0;
  }

  &.site-filter-sm {
    transition: all 0.25s ease;
    transform: translateY(-80px);
    ${o.WithSiteLayoutPadding}
    border-bottom: 1px solid var(--outline-neutral);
    background-color: #fff;
    position: fixed;
    z-index: 25;
    margin: 0;
    left: 0;
    top: 0;

    .head {
      height: 60px;

      .text {
        width: 100%;
      }
    }

    .body {
      .list-item {
        line-height: 16px;
        margin-bottom: 0;
        padding: 10px 0;
        .tag {
          text-align: left;
          width: 100%;
          border: none;
          font-size: 14px;
        }
      }
      .list-item.active {
        font-weight: 500;
      }
    }
  }

  html.with-scrolled &.site-filter-sm {
    transform: translateY(0);
    @media ${r.mqLargeMin} {
      display: none;
    }
  }

  .filter-mobile & {
    &.active {
      .head {
        .icon svg {
          transform: translateY(-2px) rotate(180deg);
        }
      }
    }

    &.site-filter-sm {
      margin: 50px 0 50px;
      transform: none;
      position: relative;
      border-top: 1px solid #1c3a1333;
      border-bottom: 1px solid #1c3a1333;
      padding: 0;
      z-index: 1;

      .head {
        border: 0;
        padding: 0;
        .text {
          width: 100%;
        }
        .title {
          display: none;
        }
        .icon {
          margin-left: auto;
          svg {
            transform: translateY(2px);
          }
        }
        .tag {
          font-size: 14px;
        }
      }

      .body {
        padding: 0;
        .list {
          padding: 0 0 25px 0;
        }

        .list-item {
          padding: 10px 0;
          &:nth-child(2) {
            padding: 0 0 10px;
          }
        }
      }
    }
  }
`,h=n.default.div.withConfig({displayName:"site-filter__Head",componentId:"sc-d715c1d1-1"})`
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
  height: 50px;

  @media ${r.mqLargeMin} {
    display: none;
  }
`,g=n.default.div.withConfig({displayName:"site-filter__Text",componentId:"sc-d715c1d1-2"})`
  display: flex;
  justify-content: flex-start;
  align-items: center;
  height: 100%;
`,u=n.default.div.withConfig({displayName:"site-filter__Title",componentId:"sc-d715c1d1-3"})`
  font-weight: 500;
  text-transform: capitalize;
  margin-right: var(--spacing-8);
`,f=n.default.div.withConfig({displayName:"site-filter__Tag",componentId:"sc-d715c1d1-4"})`
  text-overflow: ellipsis;
  overflow: ellipsis;
  white-space: nowrap;
  width: 200px;
`,x=n.default.div.withConfig({displayName:"site-filter__HeadIcon",componentId:"sc-d715c1d1-5"})`
  height: 19px;
  width: 20px;
  overflow: hidden;
  margin-left: auto;
  transform: scale(1.25) rotate(180deg) translateX(7px);

  svg {
    transition: all 0.25s ease;
  }
`,v=n.default.div.withConfig({displayName:"site-filter__Body",componentId:"sc-d715c1d1-6"})`
  transition: all 0.5s ease;
  overflow: hidden;
  width: 100%;

  @media ${r.mqLargeMin} {
    transition: none;
    max-height: none !important;
  }
`,b=n.default.div.withConfig({displayName:"site-filter__List",componentId:"sc-d715c1d1-7"})`
  display: block;
  padding-bottom: 25px;
