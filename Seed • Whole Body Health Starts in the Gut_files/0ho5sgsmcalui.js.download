  #modal-label-101 {
    .label-101 {
  .help {
    display: block;
    padding: 100px 0;
    background: var(--fill-secondary);
    > .container {
      ${m.WithSiteLayout}
    }
    > .container > .title {
      display: block;
      font-weight: 300;
      font-size: var(--font-size-1000);
      margin: 0 0 var(--spacing-48) 0;
    }
    .site-accordion {
      border-left: 0;
      border-right: 0;
      border-color: #cad1c3;
    }
    .site-accordion .head {
      @media ${p.mqSmallMax} {
        align-items: flex-start;
      }
      padding: var(--spacing-24) 0;
    }
    .site-accordion .head .title {
      display: flex;
      flex-grow: 1;
      flex-direction: column;
      @media ${p.mqLargeMin} {
        flex-direction: row;
        padding: 0;
      }
      font-weight: 400;
      font-size: var(--font-size-400);
      padding-right: var(--spacing-48);
    }
    .site-accordion .head .title span {
      font-size: var(--font-size-350);
      font-weight: 400;
    }
    .site-accordion .body .container {
      background: transparent;
      border-color: #cad1c3;
      padding-right: 0;
      padding-left: 0;
    }
  }
  .label {
    width: 700px;
    display: block;
    max-width: 100%;
    margin: 0 auto;
    @media ${p.mqLargeMin} {
      margin: 200px auto;
    }
    hr {
      border: 0;
    }
    .main {
      border: 2px solid var(--outline-primary);
      padding: var(--spacing-8);
      hr {
        display: block;
        margin: var(--spacing-8) 0;
        border-top: 1px solid var(--outline-primary);
        &.fat {
          border-width: 5px;
        }
      }
      h2 {
        padding: var(--spacing-8) 0;
        font-size: 34px;
        font-weight: 500;
        @media ${p.mqSmallMin} {
          font-size: var(--font-size-1000);
        }
        @media ${p.mqLargeMin} {
          font-size: var(--font-size-1200);
        }
      }
      h3 {
        ${m.WithFontBody}
        font-weight: 500;
        font-size: var(--font-size-400);
        text-align: center;
        padding: var(--spacing-8) 0;
        margin: -10px 0;
        border-top: 1px solid var(--outline-primary);
        border-bottom: 1px solid var(--outline-primary);
      }
      ul {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
      }
      li:first-child {
        max-width: 70%;
      }
      p {
        margin: 0;
        padding: 0;
        font-weight: 300;
        font-size: var(--font-size-350);
        @media ${p.mqSmallMin} {
          font-size: var(--font-size-400);
        }
        * {
          font-size: inherit;
          &:not(b) {
            font-weight: 300;
          }
        }
      }
    }
    .foot {
      margin: var(--spacing-24) 0 0;
      .container > div {
        margin-top: var(--spacing-8)/2;
      }
      .container > div:first-child {
        margin-top: 0;
      }
      .container > div:last-child {
        border: 2px solid var(--outline-primary);
        margin-top: var(--spacing-24);
        padding: var(--spacing-8);
      }
      p {
        margin: 0;
        font-weight: 300;
        font-size: var(--font-size-350);
        @media ${p.mqSmallMin} {
          font-size: var(--font-size-400);
        }

        *:not(b) {
          font-weight: 300;
        }
      }
    }
  }
}
.label-101.wide {
  .label {
    width: 820px;
  }
}

    .label-101 .label {
      margin: 0 auto;
      width: 400px;
      padding-right: 35px;
      .main {
        h2 {
          font-size: 34px;
        }
        p {
          font-size: var(--font-size-350);
        }
      }
      .foot {
        p {
          font-size: var(--font-size-350);
        }
      }
    }
    .label-101 .help {
      padding: 145px 0;
    }
    .label-101 .help > .container > .title {
      font-size: var(--font-size-400);
      font-weight: 500;
    }
  }
