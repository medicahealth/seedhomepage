  ${l}
  &.border {
    border: 1px solid var(--outline-neutral);
    border-right: 0;
    border-left: 0;
  }

  &.borderLightBlue {
    border: 1px solid #b6c4c4;
    border-right: 0;
    border-left: 0;
  }

  &.borderWhite {
    border: 1px solid #fff;
    border-right: 0;
    border-left: 0;
  }

  display: block;
  font-family: $siteFont;
  border-right: 0;
  border-left: 0;

  &:not(:first-child) {
    margin-top: -1px;
  }

  .head.expand {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    transition: padding-bottom 0.25s ease;
    padding: var(--spacing-24) 0;
    cursor: pointer;

    .title {
      font-family: $siteFont;
      line-height: 1.5 !important;
      font-size: var(--font-size-400);
      padding-right: 50px;
      font-weight: 500;

      * {
        font-weight: 500;
        font-size: var(--font-size-400);
        line-height: 1.5 !important;
      }
    }

    .title.large {
      font-weight: 400;
      font-size: 24px;
    }

    .title.green {
      color: var(--text-primary);
    }

    .title.white {
      color: #fff;
    }

    .icon {
      display: flex;
      align-items: flex-start;
      height: 100%;
      margin-right: var(--spacing-8);
    }

    .icon svg {
      transform: translateY(2px);

      * {
        fill: var(--fill-brand);
      }
    }

    .icon.shift-down svg {
      transform: translateY(8px);
    }

    .minus {
      display: none;

      svg {
        transform: translateY(8px);
      }

      &.shift-down svg {
        transform: translateY(14px);
      }
    }
  }

  .head.expand.small-spacing {
    padding: 12px 0;
  }

  .head.expand.extra-padding {
    padding: 24px 0 24px 8px;
  }

  .body {
    transition: max-height 0.25s ease;
    overflow: hidden;
    display: block;
    max-height: 0;
    z-index: 1;

    > .container {
      padding: 0 0 var(--spacing-24);
      text-align: left;
      display: block;
    }

    p {
      display: block;
      margin-bottom: 0;
    }

    p:empty {
      display: block;
      margin: var(--spacing-24) 0 0;
    }

    p:first-child {
      margin-top: 0;
      padding-top: 0;
    }
  }

  &.active {
    .head {
      .plus {
        display: none;
      }

      .minus {
        display: flex;
      }
    }
  }

  &.white {
    color: #fff;
  }
