  position: relative;
  display: block;
  width: 100%;

  .expand {
    padding: var(--spacing-8) var(--spacing-24);
    color: var(--text-primary);
    position: relative;
    cursor: pointer;
    display: block;
    width: 100%;
    text-align: left;
    background: transparent;
    border: 0;
    font-size: inherit;
    color: inherit;
  }

  .dropdown {
    padding: var(--spacing-24) 0;
    background: var(--fill-bright);
    overflow: hidden;
    max-height: 0;
  }

  &.active .dropdown {
    max-height: 500px;
  }
