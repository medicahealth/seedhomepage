  &:hover {
    circle {
      fill: var(--fill-brand) !important;
    }
  }
`,g=u.default.button.withConfig({displayName:"add-to-cart-button__WaitlistCtaButton",componentId:"sc-d9f4326c-1"})`
  background: var(--fill-brand);
  border: none;
  cursor: pointer;
  border-radius: 30px;

  &:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
`;e.s(["default",0,e=>{let{promoCode:a,promoCodeDiscountInfo:v}=(0,r.useContext)(o.CartContext),b=window.localStorage,x=()=>{let e=!1;if(b)try{e=!!JSON.parse(localStorage.getItem("digioh_json")||"{}")?.[m.WAITLIST_LOCAL_STORAGE_KEY]}catch{e=!1}return e?"Waitlist Joined":"Join the Waitlist"},[w,_]=(0,r.useState)(x()),j=u.default.div.withConfig({displayName:"add-to-cart-button__SiteBuy",componentId:"sc-d9f4326c-2"})`
    ${l.WithSiteLayout};
    position: relative;
    display: block;
    z-index: 2;

    @media ${c.mqLargeMin} {
      display: flex;
      justify-content: flex-end;
      min-width: 300px;
      margin-top: 0;
    }

    @media ${c.mqXXLargeMin} {
      display: flex;
      justify-content: flex-end;
      margin-top: 0;
    }

    .srp0text & {
      @media ${c.mqLargeMin} {
        justify-content: flex-start;
      }

      @media ${c.mqXXLargeMin} {
        justify-content: flex-start;
      }
    }

    .container {
      width: 100% !important;
      position: relative;

      @media ${c.mqLargeMin} {
        width: 302px;
      }
    }

    .blurb {
      margin: var(--spacing-24) 0 0;

      p {
        font-size: 0.75rem;
        margin-top: var(--spacing-4);

        * {
          font-size: 0.75rem;
        }

        strong {
          padding-right: 5px;
        }

        &.bg-green {
          display: inline-block;
          background: #b9f6a3;
          padding: 3px 5px 1px;
          margin-top: 0;
        }

        span {
          font-weight: 500;
          font-size: 0.75rem;
        }
      }
    }

    .list {
      display: block;
      position: relative;
      margin: var(--spacing-24) 0 0;
      width: 100%;

      @media ${c.mqLargeMin} {
        transition: all 0.3s ease;
      }
    }

    .list li {
      font-size: 0.875rem;
      line-height: 1.75;

      a {
        all: unset;
        text-decoration: underline;
        cursor: pointer;
      }
    }

    .button {
      position: relative;
      text-transform: inherit;
      padding: var(--spacing-24) 0;
      margin: var(--spacing-8) 0 0;
      width: 100%;

      &:focus {
        outline: solid 2px black;
        outline-offset: 3px;
      }

      i {
        transform: scale(0.8);
        padding: 0 var(--spacing-24);
      }

      * {
        font-size: 16px;
        font-weight: 500;
        color: var(--text-inverse-primary);

        @media ${c.mqLargeMin} {
          font-weight: 500;
        }
      }
    }

    .promoCodeIndicator {
      text-align: center;
      background-color: var(--guidance-secondary);
      padding: 8px 12px;
      margin-top: 15px;
      margin-bottom: 15px;
      border-radius: 24px;
