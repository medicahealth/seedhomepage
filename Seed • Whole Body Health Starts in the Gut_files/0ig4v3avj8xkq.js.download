  :root {
    --grid: repeat(var(--space-columns), minmax(0, 1fr));
    --space-columns: 4; // number of columns in a grid

    --grid-width: calc(100vw - (2 * var(--space-outer)));
    --total-gutter: 3;
    --grid-col-width: calc(
      (var(--grid-width) - var(--total-gutter) * var(--space-gutter)) /
        var(--space-columns)
    );

    @media ${u.mqMediumMin} {
      --space-columns: 8;
      --total-gutter: 7;
    }

    @media ${u.mqLargeMin} {
      --space-columns: 12;
      --total-gutter: 11;
    }

    @media ${u.mqXXLargeMin} {
      --grid-width: var(--maw);
    }
  }
