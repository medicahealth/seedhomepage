`,ta=l.default.div.withConfig({displayName:"essentials-nutrients-delivery__DeliveryPillParts",componentId:"sc-b605b180-3"})`
  position: relative;
  transition: opacity 1s;
  margin-top: 3rem;
  width: 100%;
  max-width: 100%;
  display: block;

  > span {
    position: absolute;
    z-index: 0;
    top: 0;
    right: -1rem;
    transform: translateX(30%);
    bottom: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    pointer-events: none;
  }

  > span video {
    pointer-events: auto;
  }

  video {
    position: static;
    display: block;
    height: 360px;
    width: auto;
    max-width: none;
    object-fit: cover;
    object-position: center;
    transform: none;
  }

  img {
    position: absolute;
    z-index: 0;
    left: calc(100% - 1.8125rem);
    right: auto;
    max-width: 3.625rem;
    transition:
      top 1s,
      bottom 1s;
  }

  img:nth-child(1) {
    bottom: 50%;
    transform: translateX(-50%);
    z-index: 1;
  }

  img:nth-child(2) {
    top: 50%;
    transform: translate(-50%, -50%);
  }

  img:nth-child(3) {
    top: 50%;
    transform: translateX(-50%);
    z-index: 1;
  }

  &.visible img:nth-child(1) {
    bottom: 65%;
  }

  &.visible img:nth-child(3) {
    top: 65%;
  }

  div {
    position: relative;
    z-index: 1;
    padding-top: 1rem;
    padding-right: clamp(7.25rem, 42vw, 12.5rem);
    width: 100%;
    max-width: none;
    opacity: 0;
    transition: opacity 0.75s;
    margin-left: 0.75rem;

    &::before {
      content: '';
      display: block;
      position: absolute;
      top: 0;
      width: 0;
      opacity: 0;
      height: 1px;
      background-color: var(--text-inverse-primary);
      transition:
        opacity 0.75s,
        width 1s;
    }

    &::after {
      content: '';
      display: block;
      position: absolute;
      top: 0;
      left: 0;
      transform: translateY(-2px);
      opacity: 0;
      height: 5px;
      width: 5px;
      border-radius: 100%;
      background-color: var(--text-inverse-primary);
      transition: opacity 0.25s 0.75s;
    }
  }

  div:nth-of-type(1) {
    margin-bottom: 2.25rem;

    &::before {
      left: 0;
    }
  }

  div:nth-of-type(2) {
    margin-bottom: 0;

    &::before {
      left: 0;
    }
  }

  &.visible {
    div::before {
      width: min(12.25rem, 100%);
      opacity: 1;
    }

    div::after {
      left: min(12.25rem, calc(100% - 5px));
      opacity: 1;
    }

    div:nth-of-type(1),
    div:nth-of-type(2) {
      opacity: 1;
    }
  }

  @media ${o.mqTabletMin} {
    height: 25rem;
    min-height: unset;
    width: 3.625rem;
    margin-left: auto;
    margin-right: auto;
    margin-top: 0;
    display: block;

    > span {
      position: static;
      z-index: auto;
      top: auto;
      right: auto;
      bottom: auto;
      display: unset;
      align-items: unset;
      justify-content: unset;
      width: auto;
      max-width: unset;
      pointer-events: auto;
    }

    video {
      position: absolute;
      height: 25rem;
      top: 50%;
      left: 20%;
      transform: translate(-50%, -50%);
      max-height: none;
      width: auto;
      max-width: none;
      object-fit: unset;
    }

    img {
      position: absolute;
      grid-area: unset;
      align-self: unset;
      justify-self: unset;
      max-width: 3.625rem;
      right: unset;
      left: 50%;
    }

    img:nth-child(1) {
      bottom: 50%;
      transform: translateX(-50%);
      z-index: 1;
    }

    img:nth-child(2) {
      top: 50%;
      transform: translate(-50%, -50%);
    }

    img:nth-child(3) {
      top: 50%;
      transform: translateX(-50%);
      z-index: 1;
    }

    div {
      position: absolute;
      z-index: auto;
      width: 11.5rem;
      max-width: none;
      padding-right: 0;
      margin-bottom: 0;
      transition:
        top 1s,
        opacity 0.75s;
    }

    div:nth-of-type(1) {
      top: 50%;
      right: 5.625rem;
    }

    div:nth-of-type(2) {
      top: 50%;
      right: unset;
      left: 5.625rem;

      &::after {
        left: unset;
        right: 12.25rem;
      }
    }

    &.visible {
      img:nth-child(1) {
        bottom: 65%;
      }

      img:nth-child(3) {
        top: 65%;
      }

      div::before {
        width: 12.25rem;
        opacity: 1;
      }

      div::after {
        left: 12.25rem;
        opacity: 1;
      }

      div:nth-of-type(1) {
        top: 50%;
        opacity: 1;
      }

      div:nth-of-type(2) {
        top: 30%;
        opacity: 1;

        &::before {
          left: unset;
          right: 0rem;
        }
      }
    }
  }

  @media (${o.mqXLargeMin}) {
    margin: unset;
    position: absolute;
    top: 0;
    left: 66%;
    height: 100%;
  }
