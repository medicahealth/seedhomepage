  position: relative;
  padding-left: 2rem;
  opacity: 0.25;
  transition: opacity 0.2s;

  & + & {
    margin-top: 2.5rem;
  }

  &.selected {
    opacity: 1;
  }

  &:not(:last-of-type)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 13px;
    height: calc(3rem + 100%);
    width: 1px;
    background-color: black;
    opacity: 0.25;
    transition: opacity 0.2s;
  }

  &::after {
    content: '';
    position: absolute;
    left: -3px;
    top: 13px;
    border-radius: 100%;
    height: 7px;
    width: 7px;
    background-color: black;
    opacity: 0.25;
    transition: opacity 0.2s;
  }

  &:has(~ .selected)::before,
  &:has(~ .selected)::after,
  &.selected::after {
    opacity: 1;
  }
