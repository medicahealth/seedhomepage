  .site-content {
    > .container {
      padding-top: 35px;
      @media ${m.mqLargeMin} {
        padding-top: 165px;
      }
      .swiper-wrapper {
        height: 100% !important;
      }
    }

    * {
      color: var(--text-primary);
    }

    .hero {
      display: block;
    }
    .hero > .container {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
    }
    .hero .row {
      display: flex;
      flex-direction: column;
      @media ${m.mqLargeMin} {
        flex-direction: row;
        justify-content: space-between;
        align-items: flex-start;
      }
      width: 100%;
    }
    .hero .title {
      width: 100%;
      margin-bottom: 50px;
      @media ${m.mqLargeMin} {
        width: 25%;
        margin-bottom: 0;
        font-size: var(--font-size-1200);
      }
    }
    .hero .subtext {
      @media ${m.mqLargeMin} {
        display: none;
      }
    }
    .hero .title h1 {
      font-size: 26px;
      @media ${m.mqLargeMin} {
        font-size: var(--font-size-1000);
      }
      @media ${m.mqXXLargeMin} {
        font-size: var(--font-size-1200);
      }
    }
    .hero .intro {
      display: flex;
      flex-grow: 1;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      width: 100%;
      margin-bottom: 40px;
      @media ${m.mqLargeMin} {
        width: 75%;
        margin-bottom: 0;
      }
    }
    .hero .intro p {
      ${h.WithFontHead}
      width: 100%;
      font-size: var(--font-size-400);
      font-weight: 400;
      line-height: 24px;
      @media ${m.mqLargeMin} {
        max-width: 800px;
        font-size: var(--font-size-800);
        line-height: 40px;
        font-weight: 300;
      }
    }
    .hero .intro p:empty {
      display: none;
    }
    .hero .intro p:not(:first-child) {
      margin-top: var(--spacing-24);
    }
    .hero .intro p:last-child {
      display: block;
    }
    .hero .navi {
      ${h.HideScrollbar}
      margin: 20px -30px 0;
      padding: 0 var(--spacing-32);
      display: block;
      height: auto;
      overflow-x: auto;
      white-space: nowrap;

      @media ${m.mqLargeMin} {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        align-items: center;
        margin: 100px 0 0;
        width: 100%;
        white-space: normal;
      }
    }
    .hero .navi li {
      display: inline-block;
      width: 30.25%;
      @media ${m.mqSmallMin} {
        width: 23.25%;
      }
      @media ${m.mqLargeMin} {
        width: auto;
      }
    }
    .hero .navi a {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      cursor: pointer;
      white-space: normal;
    }
    .hero .navi a span {
      font-size: 13px;
      padding: 0 var(--spacing-8);
      text-align: center;
      font-weight: 500;
      max-width: 80px;
      margin: auto;
      margin-top: 20px;
      @media ${m.mqLargeMin} {
        font-size: var(--font-size-400);
        max-width: 100%;
      }
    }
    .hero .navi img {
      margin-bottom: var(--spacing-24);
      width: 100%;
      @media ${m.mqLargeMin} {
        width: 175px;
      }
      @media ${m.mqXXLargeMin} {
        width: 223px;
      }
    }

    .head > .title {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      flex-wrap: wrap;
      border-top: 1px solid var(--outline-primary);
      margin: 70px 0 15px 0;
      position: relative;

      @media ${m.mqLargeMin} {
        justify-content: center;
        margin: 110px 0 50px;
        flex-wrap: nowrap;
      }
    }
    .head > .title * {
      ${h.WithFontHead}
      padding: 10px 0 0;
      font-size: 40px;
      @media ${m.mqLargeMin} {
        padding: 25px 0 0;
        font-size: 50px;
      }
    }
    .head .label {
      display: block;
      border-bottom: 1px dashed var(--outline-neutral);
      padding: 30px 0 40px;
      margin: 0 0 45px;
      @media ${m.mqLargeMin} {
        margin: 0 0 35px;
        padding: 0 0 35px;
        display: none;
      }
      &:empty {
        display: none;
      }
    }
    .head .label * {
      ${h.WithFontHead}
      font-size: 26px;
      line-height: 34px;
    }
    .head .num {
      margin-right: auto;
      @media ${m.mqLargeMin} {
        display: block;
        position: absolute;
        left: 0;
        top: 0;
      }
    }
    .head .coming-title {
      width: 100%;
      * {
        font-size: 16px;
        font-weight: 400;
        line-height: 24px;
        padding-top: 15px;
      }
      @media ${m.mqLargeMin} {
        padding-top: 0;
        position: absolute;
        right: 0;
        bottom: 5px;
        width: auto;
      }
    }

    .banner {
      display: block;
    }
    .banner .container {
      position: relative;
    }
    .banner .text {
      display: none;
      @media ${m.mqLargeMin} {
        display: flex;
        justify-content: center;
        align-items: center;
        position: absolute;
        top: 0;
        right: 0;
        height: 100%;
        padding: 0 var(--spacing-48) 0 0;
      }
    }
    .banner .text p {
      ${h.WithFontHead}
      font-size: var(--font-size-800);
      line-height: 40px;
      max-width: 100%;
      color: #fff;
      width: 532px;
    }
    .banner .media {
      ${(0,h.AspectRatio)("4x3")}
      @media ${m.mqLargeMin} {
        padding-bottom: 56.25%;
      }
    }
    .banner .poster {
      ${h.AspectRatioObject}
      background-size: cover;
    }

    .body {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: flex-start;
      position: relative;

      @media ${m.mqLargeMin} {
        margin: 60px 0 0;
      }
    }
    .authors {
      border-bottom: 1px dashed var(--outline-neutral);
      padding: 0 0 40px;
      margin: 0 0 45px;
      width: 100%;
      @media ${m.mqLargeMin} {
        border: 0;
        width: 25%;
        padding: 0;
        margin-bottom: 0;
        position: absolute;
        left: 0;
        top: 0;
      }
    }
    .authors > .container > .title {
      font-weight: 500;
      margin: 0 0 40px;
      @media ${m.mqLargeMin} {
        margin: 0 0 35px;
      }
    }
    .authors .author {
      display: flex;
      justify-content: flex-start;
      align-items: center;
      margin: 0 0 14px;
      width: 100%;
      &:last-child {
        margin: 0;
      }
      .text {
        margin-left: 10px;
      }
    }
    .authors .author .text * {
      font-size: var(--font-size-400);
      font-weight: 400;
    }
    .authors .author img {
      margin-right: var(--spacing-8);
      max-width: 70px;
      @media ${m.mqLargeMin} {
        margin-right: var(--spacing-24);
      }
    }

    .content {
      width: 100%;
    }
    .content > .container {
      @media ${m.mqLargeMin} {
        max-width: 445px;
        margin: auto;
        width: 100%;
      }
      @media ${m.mqXXLargeMin} {
        max-width: 645px;
      }
    }
    .content hr {
      border: 0;
      display: block;
      margin: 40px 0 45px;
      border-top: 1px dashed var(--outline-neutral);
      @media ${m.mqLargeMin} {
        margin: var(--spacing-48) 0;
      }
    }
    .content h1,
    .content h2,
    .content h3,
    .content h4,
    .content h5,
    .content h6 {
      display: block;
      font-weight: 500;
      &:not(:first-child) {
        padding: 35px 0 0;
        @media ${m.mqLargeMin} {
          padding: var(--spacing-48) 0 0;
        }
      }
    }
    .content h1 {
      font-size: var(--font-size-1200);
    }
    .content h2 {
      font-size: var(--font-size-1000);
    }
    .content h3 {
      font-size: var(--font-size-800);
    }
    .content h4 {
      font-size: var(--font-size-600);
    }
    .content h5 {
      font-size: var(--font-size-400);
    }
    .content h6 {
      font-size: var(--font-size-350);
    }
    .content p {
      font-size: var(--font-size-400);
      &:not(:first-child) {
        padding-top: var(--spacing-24);
      }
      > br:first-child {
        display: none;
      }
    }
    .content small {
      font-size: var(--font-size-300);
      font-weight: 400;
      display: block;
    }
    .content small * {
      text-decoration: none;
      font-size: var(--font-size-300);
    }

    .swiper {
      margin: var(--spacing-48) 0 0;
      @media ${m.mqLargeMin} {
        margin: var(--spacing-48) 0 0;
        height: 740px;
      }
    }
    .swiper-pagination-bullets {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 100%;
      height: 5px;
      z-index: 1;
      position: relative;
      margin: 25px 0;
      @media ${m.mqLargeMin} {
        margin: 0;
        position: absolute;
        bottom: 30px;
        left: 0;
      }
    }
    .swiper-pagination-bullet {
      display: inline-block;
      height: 5px;
      width: 5px;
      margin: 3.5px;
      border-radius: 50%;
      background: var(--fill-neutral-light);
      border: none;
      @media ${m.mqLargeMin} {
        background: transparent;
        border: 1px solid #fff;
      }
      &:hover,
      &:focus,
      &.swiper-pagination-bullet-active {
        background: var(--fill-brand);
        @media ${m.mqLargeMin} {
          background: #fff;
        }
      }
    }
    .s-coming-soon {
      .head > .title {
        justify-content: center;
      }
      .head > .title * {
        ${h.WithFontHead}
        padding: 25px 0 0;
        font-size: 30px;
        @media ${m.mqLargeMin} {
          font-size: 50px;
        }
      }
    }
  }
