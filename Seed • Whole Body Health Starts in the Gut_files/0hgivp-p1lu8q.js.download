  display: flex;
  justify-content: center;
  margin: 0 0 var(--spacing-48) 0;

  > .container {
    position: relative;
    display: block;
  }
  * {
    color: var(--text-primary);
  }

  .title {
    ${a.WithSiteLayout};
    padding-top: var(--spacing-24);
    padding-bottom: var(--spacing-24);
    display: block;

    @media ${i.mqLargeMin} {
      width: calc(100% - 60px);
      transform: translate(-50%, -50%);
      padding: 0;
      position: absolute;
      z-index: 2;
      pointer-events: none;
      left: 50%;
      top: 45%;
    }
  }

  .title .container {
    display: block;

    @media ${i.mqLargeMin} {
      padding: 0 var(--spacing-48);
    }
  }

  .title .container h1 {
    ${a.WithFontHead};
    display: inline-block;
    font-size: 26px;

    letter-spacing: var(--flag-letter-spacing-1);
    @media ${i.mqSmallMin} {
      letter-spacing: var(--flag-letter-spacing-2);
    }

    @media ${i.mqLargeMin} {
      display: block;
      font-size: 40px;
    }
  }

  .srpCouponAmount {
    background-color: #e9f0ca;
    border-radius: 24px;
    width: 70px;
    height: 18px;
    font-size: 12px;
    padding: 4px 8px 4px;
    display: inline-block;
    vertical-align: middle;
    text-align: center;
    align-items: center;
    font-weight: 500;
    margin-left: 8px;
    margin-top: -2px;
    line-height: 12px;
  }

  .most-popular-pill {
    background-color: #1c3a13;
    border-radius: 24px;
    color: #ffffff;
    width: 90px;
    height: 18px;
    font-size: 12px;
    padding-top: 4px;
    vertical-align: middle;
    text-align: center;
    align-items: center;
    font-weight: 500;
    margin-left: 8px;
    margin-top: -2px;
    line-height: 12px;
    display: none;
  }

  .srp0title .container {
    display: block;

    @media ${i.mqSmallMax} {
