    align-items: flex-start;
    margin: 0 0 100px 0;
  }
  .legend .title {
    @media ${S.mqSmallMin} {
      font-size: 30px;
    }
    font-size: 30px;
    font-weight: 300;
  }
  .legend .list {
    @media ${S.mqSmallMin} {
      margin: 0;
    }
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin: var(--spacing-48) 0 0;
  }
