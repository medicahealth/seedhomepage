        flex-direction: flex-start;
        width: 100%;
        padding: 0 25px;
      }
      .card {
        z-index: 1;
        margin-bottom: var(--spacing-4);

        @media ${S.mqSmallMin} {
          margin: 25px 0;
          width: calc(100% / 3);
          margin-bottom: var(--spacing-24);
        }
        @media ${S.mqLargeMin} {
          margin: 25px 0;
          width: 25%;
        }
        width: 50%;
        .text {
          display: block;
          padding-top: var(--spacing-8);
          @media ${S.mqSmallMin} {
            min-height: 58px;
          }
          * {
            @media ${S.mqSmallMin} {
              font-size: var(--font-size-400);
            }
            font-size: var(--font-size-300);
            font-weight: 400;
          }
        }
        .media {
          background-color: var(--fill-primary);
          position: relative;
          max-height: 385px;
          width: 100%;
          overflow: hidden;
        }
      }
    }
    .grid .card {
      .container {
        padding: 25px;

        @media ${S.mqSmallMin} {
          padding: 0 25px;
          border-right: 1px solid var(--outline-neutral);
        }
        @media ${S.mqSmallMax} {
          padding: 25px 15px;
        }
      }

      &:nth-last-child(2),
      &:last-child {
        .container {
          @media ${S.mqSmallMax} {
            padding-bottom: 0;
          }
        }
      }

      &:last-child {
        .container {
          border-right: none;
        }
      }

      &:nth-child(4n) {
        .container {
          @media ${S.mqLargeMin} {
            border-right: none !important;
          }
        }
      }
      &:nth-child(3n) {
        .container {
          @media ${S.mqSmallMin} {
            border-right: none;
          }
          @media ${S.mqLargeMin} {
            border-right: 1px solid var(--outline-neutral);
          }
        }
      }
    }
  }
  .s7 {
    @media ${S.mqSmallMin} {
      margin-top: 175px;
    }
    @media ${S.mqLargeMin} {
      margin-top: 195px;
    }

    .head {
      position: relative;
      display: block;
      overflow: hidden;
      width: 100%;
      margin: 0 0 var(--spacing-48);
      @media ${S.mqSmallMin} {
        height: 92px;
        margin: 0 0 100px;
      }
      .site-marquee {
        border: none;
        h2 {
          display: inline;
        }
      }
      * {
        ${q.WithFontHead};
        font-size: var(--font-size-1000);
        white-space: nowrap;
        @media ${S.mqSmallMin} {
          font-size: var(--font-size-1200);
        }
      }
    }
    .link {
      margin-top: 28px;
    }

    .row:nth-child(2) .col {
      margin: var(--spacing-24) 0 0;
      width: 100%;
      @media ${S.mqSmallMin} {
        margin: 96px 0 0;
        width: 50%;
      }
    }

    .list::-webkit-scrollbar {
      display: none;
    }

    .list {
      margin: 0 -30.5px;
      -ms-overflow-style: none;
      scrollbar-width: none;
      padding: 0;
      display: block;
      height: auto;
      overflow-x: auto;
      white-space: nowrap;
      margin-bottom: 20px;
      @media ${S.mqSmallMin} {
        display: flex;
        justify-content: center;
        align-items: center;
        white-space: normal;
        max-width: 1116px;
        width: 100%;
        margin: 0 auto;
        margin-bottom: 96px;
      }
      a {
        display: inline-block;
        white-space: normal;
        @media ${S.mqSmallMin} {
          display: flex;
          flex-direction: column;
          justify-content: center;
          align-items: center;
        }
      }
      span {
        display: none;
        max-width: 80px;
        text-align: center;
        margin: auto;
        font-weight: 500;
        font-size: var(--font-size-400);
        @media ${S.mqSmallMin} {
          display: inline-block;
          max-width: 100%;
        }
      }
      img {
        margin-bottom: var(--spacing-24);
        height: 125px;
        @media ${S.mqSmallMin} {
          height: auto;
        }
      }
    }
  }
  .s8 {
    margin-top: var(--spacing-48);
    @media ${S.mqLargeMin} {
      margin-top: 100px;
    }
    .container {
      padding: 0;
      max-width: 100%;
      position: relative;
    }
    .text {
      ${q.WithSiteLayoutPadding};
      ${q.WithSiteLayoutPadding};
      transform: translate(-50%, -50%);
      align-items: flex-start;
      flex-direction: column;
      display: flex;
      position: absolute;
      width: 100%;
      max-width: 1440px;
      left: 50%;
      top: 50%;

      @media ${S.mqLargeMin} {
        align-items: flex-end;
      }

      > div[data-type='button'],
      p {
        width: 220px;
      }

      p {
        @media ${S.mqSmallMin} {
          font-size: var(--font-size-800);
          line-height: 40px;
        }
        font-size: var(--font-size-600);
        line-height: 31.2px;
        font-weight: 300;
        color: var(--text-inverse-primary);
      }

      .button {
        height: 60px;
        border-width: 1px;
        margin-top: var(--spacing-24);
        @media ${S.mqSmallMin} {
          height: 50px;
          max-width: 206px;
        }

        span {
          font-size: var(--font-size-350);
          text-transform: none;
          color: var(--text-inverse-primary);
        }

        &:hover,
        &:focus {
          border-color: var(--outline-light);
          background: var(--fill-primary);
          span {
            color: var(--text-primary);
          }
        }
      }
    }
  }

  [data-vimeo-initialized] {
    display: block;
    width: 100%;
  }
  .overlay {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 100%;
    background: transparent;
  }
