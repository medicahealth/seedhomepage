    @media ${S.mqSmallMin} {
      margin: 0 0 0 var(--spacing-48);
    }
    display: flex;
    align-items: center;
    font-size: var(--font-size-350);
    margin: 0 var(--spacing-24) 0 0;
  }
  .legend .list li:before {
    content: '';
    width: 1rem;
    height: 1rem;
    display: inline-block;
    border-radius: 50%;
    transform: scale(0.9);
    margin: 0 var(--spacing-8) 0 0;
  }
  .legend .list li:nth-child(1):before {
    background: var(--fill-brand);
  }
  .legend .list li:nth-child(2):before {
    background: rgba(70,107,34, 0.5);
  }
  .legend .list li:nth-child(3):before {
    background: rgba(70,107,34, 0.25);
  }

  .taxtable {
    display: block;
    margin: 0 -20px;
    padding: 0 0 1px;
  }
  .taxtable .container {
    width: 100%;
  }

  @media ${S.mqSmallMin} {
    .taxtable .a {
      display: block;
      margin-bottom: 4rem;
    }
    .taxtable .a .b {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      margin-bottom: 1rem;
    }
    .taxtable .a .b .c {
      position: relative;
      padding: 0 var(--spacing-24);
    }
    .taxtable span {
      border-radius: 1.25rem;
      min-height: 2.5rem;
      text-align: center;
      display: block;
      background-color: rgba(70,107,34, 0.25);
      font-weight: 500;
      font-size: 12px;
      color: var(--text-primary);

      line-height: calc(2.5rem - 4px);
      padding-top: 4px;
    }
    .taxtable span:empty {
      opacity: 0;
    }
    .taxtable .a .b0 .c span {
      background: var(--fill-brand);
      font-style: italic;
      color: #fff;
      font-size: 14px;
      line-height: 2.5rem;
      padding-top: 0;
    }
    .taxtable .a .b1 {
      margin-top: var(--spacing-48);
    }
    .taxtable .a .b1 .c span:before {
      content: '';
      position: absolute;
      left: 50%;
      bottom: 100%;
      width: 1px;
      height: var(--spacing-48);
      border-right: 1px dashed rgba(0,0,0, 0.5);
    }
    .taxtable .a .b2 {
      margin-top: var(--spacing-48);
    }
    .taxtable .a .b2 .c span:before {
      content: '';
      position: absolute;
      left: 50%;
      bottom: 100%;
      width: 1px;
      height: var(--spacing-48);
      border-right: 1px dashed rgba(0,0,0, 0.5);
    }
    .taxtable .a .b1 .c span {
      background: rgba(70,107,34, 0.5);
      font-size: 14px;
      font-style: italic;
      line-height: 2.5rem;
      padding-top: 0;
    }
    .taxtable .a0 .c {
      width: 20%;
    }
    .taxtable .a0 .b0 .c {
      width: 100%;
    }
    .taxtable .a1 .c {
      width: 25%;
    }
    .taxtable .a1 .b0 .c {
      width: 50%;
    }
    .taxtable .a2 .c {
      width: calc(100% / 3);
    }
  }
  @media ${S.mqSmallMax} {
    .taxtable .a {
      display: block;
      margin-bottom: 4rem;
    }
    .taxtable .a .b {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      margin-bottom: var(--spacing-48);
    }
    .taxtable .a .b .c {
      width: 100%;
      position: relative;
      margin: var(--spacing-8) 0 0;
      padding: 0 var(--spacing-24);
    }
    .taxtable .a .b .c span {
      background-color: rgba(70,107,34, 0.25);
      border-radius: 1.25rem;
      line-height: 2.5rem;
      height: 2.5rem;
      text-align: center;
      display: block;
      font-weight: 400;
      font-size: 14px;
      color: var(--text-primary);
      float: right;
      width: 50%;
      position: relative;
    }
    .taxtable .a .b .c span:before {
      content: '';
      width: 2rem;
      position: absolute;
      right: 100%;
      top: 50%;
      border-bottom: 1px dashed rgba(0,0,0, 0.5);
    }
    .taxtable .a .b .c span:after {
      content: '';
      height: 4.25rem;
      position: absolute;
      left: -2rem;
      bottom: 20px;
      border-left: 1px dashed rgba(0,0,0, 0.5);
    }
    .taxtable .a .b .c0 {
      margin: 0;
    }
    .taxtable .a .b .c0 span {
      transform: translateX(-50%);
      background: rgba(70,107,34, 0.5);
      margin: 0 0 0 50%;
    }
    .taxtable .a .b0 .c0 span {
      transform: translate(0, 0);
      background: var(--fill-brand);
      font-style: italic;
      color: #fff;
      width: 100%;
      margin: 0;
    }
    .taxtable .a .b0 .c0 span:before {
      display: none;
    }
    .taxtable .a .b .c1 {
      margin: var(--spacing-48) 0 0;
    }

    .taxtable .a .b1 .c0 span:after {
      height: 4.25rem;
    }
    .taxtable .a0 .b2 .c0 span:after {
      height: 11rem;
    }
    .taxtable .a0 .b3 .c0 span:after {
      height: 14.25rem;
    }
    .taxtable .a0 .b4 .c0 span:after {
      height: 11rem;
    }
    .taxtable .a0 .b5 .c0 span:after {
      height: 24rem;
    }

    .taxtable .a1 .b2 .c0 span:after {
      height: 14.25rem;
    }
    .taxtable .a2 .b2 .c0 span:after {
      height: 11rem;
    }
  }
}
