  .site-content {
    * {
      color: var(--text-primary);
    }
  }

  .site-filter-lg {
    display: none;
  }

  .site-filter {
    .body .list-item {
      &.active {
        display: block;
      }
    }
  }

  &.with-scrolled header {
    opacity: 0;
    @media ${S.mqLargeMin} {
      opacity: 1;
    }
  }

  [data-mobile-only] {
    display: none !important;
    @media ${S.mqSmallMax} {
      display: block !important;
    }
  }

  [data-desktop-only] {
    display: block !important;
    @media ${S.mqSmallMax} {
      display: none !important;
    }
  }

  #modal-taxonomy {
  .legend {
    @media ${S.mqSmallMin} {
      align-items: center;
      flex-direction: row;
