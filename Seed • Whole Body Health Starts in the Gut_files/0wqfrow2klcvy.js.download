  width: 100%;

  * {
    font-size: 16px;
  }

  &.active {
    .head {
      .title {
        font-weight: 500;
      }
      .icon svg {
        transform: translateY(-2px) rotate(180deg);
      }
    }
  }

  &.site-filter-lg {
    padding: 0 var(--spacing-48) 0 0;
    position: relative;
    width: 100%;
    border: 0;
    margin: 0;
  }

  &.site-filter-sm {
    transition: all 0.25s ease;
    transform: translateY(-80px);
    ${r.WithSiteLayoutPadding}
    border-bottom: 1px solid var(--outline-neutral);
    background-color: #fff;
    position: fixed;
    z-index: 25;
    margin: 0;
    left: 0;
    top: 0;

    .head {
      height: 60px;

      .text {
        width: 100%;
      }
    }

    .body {
      .list-item {
        line-height: 16px;
        margin-bottom: 0;
        padding: 10px 0;
        .tag {
          text-align: left;
          width: 100%;
          border: none;
          font-size: 14px;
        }
      }
      .list-item.active {
        font-weight: 500;
      }
    }
  }

  html.with-scrolled &.site-filter-sm {
    transform: translateY(0);
    @media ${l.mqLargeMin} {
      display: none;
    }
  }

  .filter-mobile & {
    &.active {
      .head {
        .icon svg {
          transform: translateY(-2px) rotate(180deg);
        }
      }
    }

    &.site-filter-sm {
      margin: 50px 0 50px;
      transform: none;
      position: relative;
      border-top: 1px solid #1c3a1333;
      border-bottom: 1px solid #1c3a1333;
      padding: 0;
      z-index: 1;

      .head {
        border: 0;
        padding: 0;
        .text {
          width: 100%;
        }
        .title {
          display: none;
        }
        .icon {
          margin-left: auto;
          svg {
            transform: translateY(2px);
          }
        }
        .tag {
          font-size: 14px;
        }
      }

      .body {
        padding: 0;
        .list {
          padding: 0 0 25px 0;
        }

        .list-item {
          padding: 10px 0;
          &:nth-child(2) {
            padding: 0 0 10px;
          }
        }
      }
    }
  }
