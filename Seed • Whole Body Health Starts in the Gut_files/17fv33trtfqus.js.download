        display: block;
        font-size: 13px;
        padding-top: var(--spacing-8);
        font-weight: 400;
        line-height: 1.5;
      }
    }
  }

  .cursor-nav {
    flex-wrap: wrap;
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 100%;
    z-index: 2;
    top: -40px;
    border: 1px;
    display: flex;
    align-items: center;
