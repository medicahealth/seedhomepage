  .planSelector {
    display: flex;
    flex-direction: column;
    margin-top: 24px;

    .inputContainer {
      z-index: 1000;
      margin: 10px 0px;
      padding: 10px;
      border: 1px solid #d2d8d0;
      cursor: pointer;
    }

    .selectedInputContainer {
      z-index: 1000;
      margin: 10px 0px;
      padding: 10px;
      border: 1px solid #d2d8d0;
      cursor: pointer;
      background-color: #d2d8d0;
    }

    .productTitle {
      font-weight: 500;
    }

    h2 {
      padding: 0px !important;
      line-height: 1;
      pointer-events: none;
    }

    .radioContent {
      pointer-events: none;
      display: flex;
      flex-direction: row;
      justify-content: space-between;
      vertical-align: top;
    }

    input[type='radio']:checked {
      accent-color: #1c3a13;
    }

    input[type='radio'] {
      background: #d2d8d0;
      margin-top: 25px;
    }

    .radioContent .srpPrice {
      font-size: 16px;
      font-weight: 500;
    }

    .radioContent .srpPriceCrossed {
      font-size: 14px;
      font-weight: 500;
      text-decoration: line-through;
      color: #778971;
    }

    .radioContent .srpPriceContainer {
      pointer-events: none;
      height: 62px;
      margin-top: -46px;
    }

    .radioContent .srpBillingPeriod {
      font-size: 12px;
      font-family: var(--flag-font-family);
      font-weight: 400;
      letter-spacing: normal;
      font-style: normal;
      line-height: 16px;
      color: '#1C3A13';
    }

    .radioContent .srpProductDescription {
      font-size: 12px !important;
      font-family: var(--flag-font-family);
      font-weight: 400;
      letter-spacing: normal;
      font-style: normal;
      line-height: 16px;
      color: '#1C3A13';
    }

    .radioContent .srpDescriptionContainer {
      margin-left: 26px;
      display: block;
      margin-top: -46px;
    }

    .radioContent .srpDiscountSvg {
      padding: 3px 0px 0px 6px !important;
      overflow: visible;
      shape-rendering: crispEdges;
    }
  }

  .srpHero .srp0text .srp0title p {
    display: none;
  }

  .hero .text > .container {
    @media ${i.mqLargeMin} {
      width: 302px;
      max-width: 100%;
      float: right;
    }
  }

  .hero .text {
    b {
      display: block;
      margin: 0 0 10px;
    }

    p {
      display: block;
      font-size: 16px;
    }

    h2,
    h6 {
      display: block;
